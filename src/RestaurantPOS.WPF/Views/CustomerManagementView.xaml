<UserControl x:Class="RestaurantPOS.WPF.Views.CustomerManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RestaurantPOS.WPF.Converters"
             Background="{StaticResource PrimaryBgBrush}"
             FontFamily="{StaticResource AppFont}"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Reusable styles ── -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridHeaderBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: HEADER ═══ -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="20,14" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Customer Management" FontSize="22" FontWeight="Bold" Foreground="#1A237E"/>
                    <TextBlock Text="View, add, edit customers and their order history" FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource Btn}" Content="&#xE72C;  Refresh" Background="#2196F3"
                            Command="{Binding RefreshCommand}" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets, Segoe UI"/>
                    <Button Style="{StaticResource Btn}" Content="+ Add Customer" Background="#4CAF50"
                            Command="{Binding AddCustomerCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ ROW 1: STAT CARDS ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Customers -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="20,14" Margin="0,0,8,0">
                <Border.Effect><DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Customers" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding TotalCustomers}" FontSize="26" FontWeight="Bold" Foreground="#1565C0" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Total Spent -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="20,14" Margin="0,0,8,0">
                <Border.Effect><DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Revenue" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding TotalSpentDisplay}" FontSize="26" FontWeight="Bold" Foreground="#2E7D32" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Total Orders -->
            <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="20,14" Margin="0,0,8,0">
                <Border.Effect><DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Orders" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding TotalOrders}" FontSize="26" FontWeight="Bold" Foreground="#E65100" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Gold/Platinum -->
            <Border Grid.Column="3" Background="White" CornerRadius="6" Padding="20,14">
                <Border.Effect><DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Gold / Platinum" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding GoldPlatinumCount}" FontSize="26" FontWeight="Bold" Foreground="#FF8F00" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ ROW 2: MAIN CONTENT (Grid + Detail) ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Customer Grid ── -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="0" Margin="0,0,8,0">
                <Border.Effect><DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar: Search + Filter -->
                    <Border Grid.Row="0" Background="#F5F5F5" Padding="12,8" CornerRadius="6,6,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="#999" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border BorderBrush="#CCC" BorderThickness="1" Background="White"
                                        CornerRadius="3" Padding="6,4" MinWidth="220">
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="13" VerticalAlignment="Center"
                                             ToolTip="Search by name, phone, or email..."/>
                                </Border>
                                <TextBlock Text="Tier:" FontSize="12" Foreground="#666"
                                           VerticalAlignment="Center" Margin="16,0,6,0"/>
                                <ComboBox ItemsSource="{Binding TierOptions}"
                                          SelectedItem="{Binding SelectedTierFilter}"
                                          Width="100" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#888">
                                <Run Text="{Binding Customers.Count, Mode=OneWay}"/>
                                <Run Text=" customers"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E0E0E0"
                              BorderThickness="0"
                              Background="White"
                              RowStyle="{StaticResource DgRow}"
                              CellStyle="{StaticResource DgCell}"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding SelectCustomerCommand}"
                                          CommandParameter="{Binding SelectedCustomer}"/>
                        </DataGrid.InputBindings>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Serial}" Width="40"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="180"/>
                            <DataGridTextColumn Header="Orders" Binding="{Binding OrderCount}" Width="60"/>
                            <DataGridTemplateColumn Header="Tier" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E0E0E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tier}" Value="Gold">
                                                            <Setter Property="Background" Value="#FFD54F"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tier}" Value="Platinum">
                                                            <Setter Property="Background" Value="#B0BEC5"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tier}" Value="Silver">
                                                            <Setter Property="Background" Value="#CFD8DC"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Tier}" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Total Spent" Binding="{Binding TotalSpent}" Width="100"/>
                            <DataGridTextColumn Header="Since" Binding="{Binding CreatedAt}" Width="90"/>
                            <DataGridTemplateColumn Header="Actions" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource SmallBtn}" Content="View" Background="#1565C0"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource SmallBtn}" Content="Edit" Background="#FF8F00"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.EditCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <Button Style="{StaticResource SmallBtn}" Content="Delete" Background="#E53935"
                                                    Command="{Binding DataContext.DeleteCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── RIGHT: Detail Panel (visible when customer selected) ── -->
            <Border Grid.Column="1" Width="340" Background="White" CornerRadius="6" Padding="20,16"
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <Border.Effect><DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Customer Details" FontSize="16" FontWeight="Bold" Foreground="#1A237E"/>
                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Command="{Binding CloseDetailCommand}"/>
                    </Grid>

                    <!-- Info -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#333"
                                   Text="{Binding DetailName}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding DetailPhone}" FontSize="13" Foreground="#555"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding DetailEmail}" FontSize="12" Foreground="#555"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding DetailAddress}" FontSize="12" Foreground="#555"
                                       TextWrapping="Wrap" MaxWidth="260"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Stats Cards -->
                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="4" Padding="8,6" Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Tier" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DetailTier}" FontSize="14" FontWeight="Bold"
                                           Foreground="#1565C0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="4" Padding="8,6" Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Spent" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DetailTotalSpent}" FontSize="14" FontWeight="Bold"
                                           Foreground="#2E7D32" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="4" Padding="8,6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Orders" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DetailOrderCount}" FontSize="14" FontWeight="Bold"
                                           Foreground="#E65100" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Order History -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Order History" FontSize="13" FontWeight="Bold"
                                   Foreground="#333" Margin="0,0,0,6"/>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding CustomerOrders}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEE"
                                  BorderThickness="1" BorderBrush="#E0E0E0"
                                  Background="White"
                                  RowStyle="{StaticResource DgRow}"
                                  CellStyle="{StaticResource DgCell}"
                                  ColumnHeaderStyle="{StaticResource DgHeader}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Order #" Binding="{Binding OrderNumber}" Width="70"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="85"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="55"/>
                                <DataGridTemplateColumn Header="Items" Width="42">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Items}" FontSize="10"
                                                       ToolTip="{Binding ItemsSummary}"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Status" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E0E0E0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                                <Setter Property="Background" Value="#C8E6C9"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Void">
                                                                <Setter Property="Background" Value="#FFCDD2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
