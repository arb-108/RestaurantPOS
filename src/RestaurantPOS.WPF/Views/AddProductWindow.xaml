<Window x:Class="RestaurantPOS.WPF.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Product"
        Height="540" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="FldInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CaretBrush" Value="#1565C0"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FldCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style x:Key="FldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="2,0,0,3"/>
        </Style>

        <Style x:Key="DlgBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="16,0" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>       <!-- Form -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Form ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Fields -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Item Name -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Category | Kitchen -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Cost / Sale -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- SKU / Barcode -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Max Disc / Prep Time -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Display Order / Description -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>  <!-- Active -->
                </Grid.RowDefinitions>

                <!-- Item Name -->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                    <TextBlock Text="ITEM NAME" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtItemName" Style="{StaticResource FldInput}"/>
                </StackPanel>

                <!-- Category | Kitchen -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="CATEGORY" Style="{StaticResource FldLabel}"/>
                    <ComboBox x:Name="CmbCategory" Style="{StaticResource FldCombo}" DisplayMemberPath="Name"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="KITCHEN / SECTION" Style="{StaticResource FldLabel}"/>
                    <ComboBox x:Name="CmbKitchen" Style="{StaticResource FldCombo}" DisplayMemberPath="Name"/>
                </StackPanel>

                <!-- Cost | Sale -->
                <StackPanel Grid.Row="4" Grid.Column="0">
                    <TextBlock Text="COST PRICE" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtCostPrice" Style="{StaticResource FldInput}"/>
                </StackPanel>
                <StackPanel Grid.Row="4" Grid.Column="2">
                    <TextBlock Text="SALE PRICE" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtSalePrice" Style="{StaticResource FldInput}"/>
                </StackPanel>

                <!-- SKU | Barcode -->
                <StackPanel Grid.Row="6" Grid.Column="0">
                    <TextBlock Text="SKU" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtSKU" Style="{StaticResource FldInput}"/>
                </StackPanel>
                <StackPanel Grid.Row="6" Grid.Column="2">
                    <TextBlock Text="BARCODE" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtBarcode" Style="{StaticResource FldInput}"/>
                </StackPanel>

                <!-- Max Disc | Prep Time -->
                <StackPanel Grid.Row="8" Grid.Column="0">
                    <TextBlock Text="MAX DISCOUNT" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtMaxDisc" Style="{StaticResource FldInput}"/>
                </StackPanel>
                <StackPanel Grid.Row="8" Grid.Column="2">
                    <TextBlock Text="PREP TIME (MIN)" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtPrepTime" Style="{StaticResource FldInput}"/>
                </StackPanel>

                <!-- Display Order | Description -->
                <StackPanel Grid.Row="10" Grid.Column="0">
                    <TextBlock Text="DISPLAY ORDER" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtDisplayOrder" Style="{StaticResource FldInput}"/>
                </StackPanel>
                <StackPanel Grid.Row="10" Grid.Column="2">
                    <TextBlock Text="DESCRIPTION" Style="{StaticResource FldLabel}"/>
                    <TextBox x:Name="TxtDescription" Style="{StaticResource FldInput}"/>
                </StackPanel>

                <!-- Active -->
                <StackPanel Grid.Row="12" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkActive" IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Active" FontSize="13" FontWeight="SemiBold" Foreground="#475569"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Right: Image -->
            <Border Grid.Column="2" CornerRadius="10" Background="#F8FAFC"
                    BorderBrush="#E2E8F0" BorderThickness="1.5" VerticalAlignment="Top"
                    Height="160" Margin="0,16,0,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="20" Background="#E2E8F0"
                            HorizontalAlignment="Center" Margin="0,0,0,6">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Item Image" FontSize="11" FontWeight="SemiBold"
                               Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click to upload" FontSize="9" Foreground="#CBD5E1"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Buttons ── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnManageRecipe" Background="#00897B" Style="{StaticResource DlgBtn}"
                    Click="ManageRecipe_Click" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtRecipeBtn" Text="Manage Recipe" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Content="Cancel" Background="#EF4444" Style="{StaticResource DlgBtn}"
                    Click="Cancel_Click" Margin="0,0,10,0"/>
            <Button Content="Save" Background="#1565C0" Style="{StaticResource DlgBtn}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
