<Window x:Class="RestaurantPOS.WPF.Views.AddSupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Supplier"
        Height="440" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Grid Margin="20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                <TextBlock Text="SUPPLIER NAME" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="2,0,0,3"/>
                <TextBox x:Name="TxtName" FontSize="13" Height="36" Padding="10,5"
                         VerticalContentAlignment="Center" BorderBrush="#D0D7DE" Background="White"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0">
                <TextBlock Text="CONTACT PERSON" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="2,0,0,3"/>
                <TextBox x:Name="TxtContact" FontSize="13" Height="36" Padding="10,5"
                         VerticalContentAlignment="Center" BorderBrush="#D0D7DE" Background="White"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="2">
                <TextBlock Text="PHONE" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="2,0,0,3"/>
                <TextBox x:Name="TxtPhone" FontSize="13" Height="36" Padding="10,5"
                         VerticalContentAlignment="Center" BorderBrush="#D0D7DE" Background="White"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0">
                <TextBlock Text="EMAIL" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="2,0,0,3"/>
                <TextBox x:Name="TxtEmail" FontSize="13" Height="36" Padding="10,5"
                         VerticalContentAlignment="Center" BorderBrush="#D0D7DE" Background="White"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="2">
                <TextBlock Text="CITY" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="2,0,0,3"/>
                <TextBox x:Name="TxtCity" FontSize="13" Height="36" Padding="10,5"
                         VerticalContentAlignment="Center" BorderBrush="#D0D7DE" Background="White"/>
            </StackPanel>

            <StackPanel Grid.Row="6" Grid.ColumnSpan="3">
                <TextBlock Text="ADDRESS" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="2,0,0,3"/>
                <TextBox x:Name="TxtAddress" FontSize="13" Height="36" Padding="10,5"
                         VerticalContentAlignment="Center" BorderBrush="#D0D7DE" Background="White"/>
            </StackPanel>

            <StackPanel Grid.Row="8" Grid.ColumnSpan="3">
                <TextBlock Text="NOTES" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="2,0,0,3"/>
                <TextBox x:Name="TxtNotes" FontSize="13" Height="36" Padding="10,5"
                         VerticalContentAlignment="Center" BorderBrush="#D0D7DE" Background="White"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Width="100" Height="38"
                    FontSize="13" FontWeight="SemiBold" Foreground="White" Cursor="Hand" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#EF4444" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.88"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Save" Click="Save_Click" Width="100" Height="38"
                    FontSize="13" FontWeight="SemiBold" Foreground="White" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#1565C0" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.88"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
