<UserControl x:Class="RestaurantPOS.WPF.Views.StockManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RestaurantPOS.WPF.Converters"
             Background="#F0F2F5" FontFamily="Segoe UI" Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:PaisaToCurrencyConverter x:Key="PaisaToCurrency"/>
        <conv:StockLevelToWidthConverter x:Key="StockToWidth"/>
        <conv:StockStatusConverter x:Key="StockStatus"/>
        <conv:StockStatusColorConverter x:Key="StockStatusColor"/>
        <conv:StockBarColorConverter x:Key="StockBarColor"/>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>

        <!-- Action button -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- DataGrid styles -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFBFC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF5FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#111827"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stat Card -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar category button -->
        <Style x:Key="CatBtn" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="10,8" Margin="0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Alert + Stats -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- HEADER BAR -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,12" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.04" Color="#000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Stock Management" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Track inventory, reorder levels and movements" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Background="#6366F1" Style="{StaticResource Btn}" Command="{Binding RefreshCommand}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                    <Button Background="#D97706" Style="{StaticResource Btn}" Command="{Binding AddStockItemCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add Item"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LOW STOCK ALERT + STATS ROW -->
        <StackPanel Grid.Row="1">
            <!-- Low Stock Alert -->
            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="10" Padding="16,10" Margin="0,0,0,10"
                    Visibility="{Binding LowStockCount, Converter={StaticResource IntToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock VerticalAlignment="Center" FontSize="13">
                        <Run Text="{Binding LowStockCount, Mode=OneWay}" FontWeight="Bold" Foreground="#DC2626"/>
                        <Run Text=" items below reorder level" Foreground="#111827"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Stats Cards -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="TOTAL ITEMS" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalItems}" FontSize="26" FontWeight="Bold" Foreground="#111827" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="LOW STOCK" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LowStockCount}" FontSize="26" FontWeight="Bold" Foreground="#D97706" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="STOCK VALUE" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding StockValueText}" FontSize="22" FontWeight="Bold" Foreground="#059669" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Margin="0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatCard}">
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="SUPPLIERS" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ActiveSupplierCount}" FontSize="26" FontWeight="Bold" Foreground="#2563EB" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <!-- MAIN CONTENT: Sidebar + Table -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Background="White" CornerRadius="12,0,0,12" BorderBrush="#E5E7EB" BorderThickness="1,1,0,1" Margin="0,0,10,0"/>

            <!-- MAIN TABLE -->
            <Border Grid.Column="1" Background="White" CornerRadius="0,12,12,0" BorderBrush="#E5E7EB" BorderThickness="0,1,1,1" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Toolbar -->
                        <RowDefinition Height="*"/>
                        <!-- DataGrid -->
                    </Grid.RowDefinitions>

                    <!-- Table Toolbar -->
                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" MinWidth="240" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="10,0,6,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Height="30" Padding="4,4" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding StockStatusOptions}" SelectedItem="{Binding SelectedStatus}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding ItemCountText}" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding StockItems}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              GridLinesVisibility="None" BorderThickness="0" FontSize="13" RowHeight="44"
                              HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" AlternationCount="2"
                              ColumnHeaderStyle="{StaticResource DgHeader}" RowStyle="{StaticResource DgRow}" CellStyle="{StaticResource DgCell}"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="ITEM NAME" Width="auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#111827"/>
                                            <TextBlock Text="{Binding StockCategory}" FontSize="10" Foreground="#9CA3AF"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="CURRENT STOCK" Width="auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="60" Height="4" Background="#E5E7EB" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border CornerRadius="2" HorizontalAlignment="Left"
                                                    Width="{Binding ., Converter={StaticResource StockToWidth}}"
                                                    Background="{Binding ., Converter={StaticResource StockBarColor}}"/>
                                            </Border>
                                            <TextBlock FontSize="12" Foreground="#111827">
                                            <Run Text="{Binding CurrentStock, Mode=OneWay, StringFormat=G}"/><Run Text=" "/><Run Text="{Binding Unit, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="MIN LEVEL" Width="auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12" Foreground="#6B7280">
                                        <Run Text="{Binding ReorderLevel, Mode=OneWay, StringFormat=G}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="STATUS" Width="auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left"
                                            Background="{Binding ., Converter={StaticResource StockStatusColor}, ConverterParameter=bg}">
                                            <TextBlock Text="{Binding ., Converter={StaticResource StockStatus}}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{Binding ., Converter={StaticResource StockStatusColor}, ConverterParameter=fg}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="SUPPLIER" Binding="{Binding Supplier.Name, FallbackValue='--'}" Width="auto">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="ACTIONS" Width="auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource SmallBtn}" Content="Restock"
                                                Command="{Binding DataContext.RestockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0" Foreground="#D97706" BorderBrush="#FDE68A"/>
                                            <Button Style="{StaticResource SmallBtn}" Content="Edit"
                                                Command="{Binding DataContext.EditStockItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                            <Button Style="{StaticResource SmallBtn}" Content="Waste"
                                                Command="{Binding DataContext.RecordWastageCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Foreground="#DC2626" BorderBrush="#FECACA"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
