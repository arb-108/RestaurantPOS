<Window x:Class="RestaurantPOS.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:RestaurantPOS.WPF.Converters"
        mc:Ignorable="d"
        Title="POS System"
        Width="640" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#4682B4"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Caption buttons -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A6F95"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Keypad button -->
        <Style x:Key="PadButton" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="BorderBrush" Value="#B5B5B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CFCFCF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PadButtonSmall" TargetType="Button" BasedOn="{StaticResource PadButton}">
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Green Login button -->
        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#2E8B3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#26732F"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#1F6227"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Professional TextBox -->
        <Style TargetType="TextBox" x:Key="LoginInput">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4682B4"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox" x:Key="LoginInputPwd">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4682B4"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer steel-blue border -->
    <Border BorderBrush="#4682B4" BorderThickness="2" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ CUSTOM TITLE BAR ════════ -->
            <Border Grid.Row="0" Background="#4682B4"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="POS System"
                               Foreground="White" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource CaptionButton}"
                                Content="&#xE968;" Click="DbSettings_Click" ToolTip="Database Settings"/>
                        <Button Style="{StaticResource CaptionButton}"
                                Content="&#xE921;" Click="Minimize_Click" ToolTip="Minimize"/>
                        <Button Style="{StaticResource CaptionCloseButton}"
                                Content="&#xE8BB;" Click="Close_Click" ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════ BODY ════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: logo -->
                <Grid Grid.Column="0" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Image Grid.Row="0" x:Name="LogoImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="14,10"
                           MaxWidth="220" MaxHeight="220"/>
                    <Border Grid.Row="1" Background="#EDEDED" Padding="6,5">
                        <TextBlock Text="Software : ARB  +923187609675 | arb108.com"
                                   FontSize="10" Foreground="#555"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- GREY PARTITION -->
                <Border Grid.Column="1" Width="2" Background="#9CA3AF"/>

                <!-- RIGHT: login (WHITE) -->
                <Border Grid.Column="2" Background="White" Padding="14,8">
                    <Grid>
                        <!-- ─── PIN MODE ─── -->
                        <Grid Visibility="{Binding ShowPinPad, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- PIN mask display -->
                            <Border Grid.Row="0" Background="White"
                                    BorderBrush="#CBD5E1" BorderThickness="1"
                                    CornerRadius="4" Padding="10,6"
                                    Margin="0,0,0,6" MinWidth="258" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PinMask, FallbackValue=''}"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           Foreground="#222" MinHeight="24"/>
                            </Border>

                            <!-- 4×3 Keypad -->
                            <UniformGrid Grid.Row="1" Columns="3" Rows="4" HorizontalAlignment="Center">
                                <Button Content="7" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="7"/>
                                <Button Content="8" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="8"/>
                                <Button Content="9" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="9"/>

                                <Button Content="4" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="4"/>
                                <Button Content="5" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="5"/>
                                <Button Content="6" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="6"/>

                                <Button Content="1" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="1"/>
                                <Button Content="2" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="2"/>
                                <Button Content="3" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="3"/>

                                <Border Background="Transparent"/>
                                <Button Content="0" Style="{StaticResource PadButton}"
                                        Command="{Binding AppendPinCommand}" CommandParameter="0"/>
                                <Button Content="Backspace" Style="{StaticResource PadButtonSmall}"
                                        Command="{Binding BackspacePinCommand}"/>
                            </UniformGrid>

                            <!-- LOGIN button -->
                            <Button Grid.Row="2" x:Name="BtnLoginPin" Content="Login"
                                    Style="{StaticResource LoginButton}"
                                    Margin="3,6,3,0"
                                    Command="{Binding LoginWithPinCommand}"
                                    IsDefault="True"/>

                            <!-- Switch mode link -->
                            <Button Grid.Row="3" Command="{Binding ToggleLoginModeCommand}"
                                    HorizontalAlignment="Center" Margin="0,4,0,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="Switch to Login Mode" TextDecorations="Underline"
                                                   Foreground="#4682B4" FontSize="11" Cursor="Hand"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Error (reserved) -->
                            <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="#B91C1C"
                                       FontSize="11" HorizontalAlignment="Center"
                                       Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="260"
                                       MinHeight="14"/>
                        </Grid>

                        <!-- ─── PASSWORD MODE ─── -->
                        <Grid Visibility="{Binding ShowPasswordLogin, Converter={StaticResource BoolToVis}}"
                              VerticalAlignment="Center" HorizontalAlignment="Stretch"
                              MaxWidth="270">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Username:" FontSize="12"
                                       Foreground="#333" Margin="0,0,0,3"/>
                            <TextBox Grid.Row="1" x:Name="TxtUsername" Style="{StaticResource LoginInput}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     TabIndex="0" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="Password:" FontSize="12"
                                       Foreground="#333" Margin="0,0,0,3"/>
                            <PasswordBox Grid.Row="3" x:Name="TxtPassword" Style="{StaticResource LoginInputPwd}"
                                         PasswordChanged="TxtPassword_PasswordChanged"
                                         TabIndex="1" Margin="0,0,0,10"/>

                            <Button Grid.Row="4" x:Name="BtnLoginPwd" Content="Login"
                                    Style="{StaticResource LoginButton}"
                                    Command="{Binding LoginWithPasswordCommand}"
                                    TabIndex="2" IsDefault="True"/>

                            <Button Grid.Row="5" Command="{Binding ToggleLoginModeCommand}"
                                    HorizontalAlignment="Center" Margin="0,8,0,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="Switch to PIN Mode" TextDecorations="Underline"
                                                   Foreground="#4682B4" FontSize="11" Cursor="Hand"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Grid.Row="6" Text="{Binding ErrorMessage}" Foreground="#B91C1C"
                                       FontSize="11" HorizontalAlignment="Center"
                                       Margin="0,5,0,0" TextWrapping="Wrap" MinHeight="14"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
