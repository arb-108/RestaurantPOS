                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="QTY" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Qty}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="TOTAL" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Total}" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Summary Section -->
                    <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Category total (shown when filtered) -->
                            <TextBlock Grid.Column="0" Text="{Binding SaleCategoryTotal}" FontSize="14" FontWeight="Bold"
                                       Foreground="#0891B2" VerticalAlignment="Center"
                                       Visibility="{Binding IsCategoryMode, Converter={StaticResource BoolToVis}}"/>

                            <!-- Summary cards -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- Sale -->
                                <Border Background="#EFF6FF" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Sale" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SaleTotal}" FontSize="16" FontWeight="Bold" Foreground="#2563EB"/>
                                    </StackPanel>
                                </Border>
                                <!-- Discount -->
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Discount" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SaleDiscount}" FontSize="16" FontWeight="Bold" Foreground="#D97706"/>
                                    </StackPanel>
                                </Border>
                                <!-- G.Total -->
                                <Border Background="#F0FDF4" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="G.Total" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SaleGrandTotal}" FontSize="16" FontWeight="Bold" Foreground="#059669"/>
                                    </StackPanel>
                                </Border>
                                <!-- Expenses -->
                                <Border Background="#FEF2F2" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Expenses" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SaleExpenses}" FontSize="16" FontWeight="Bold" Foreground="#DC2626"/>
                                    </StackPanel>
                                </Border>
                                <!-- Cash In Hand -->
                                <Border Background="#ECFDF5" CornerRadius="8" Padding="16,10">
                                    <StackPanel>
                                        <TextBlock Text="Cash In Hand" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SaleCashInHand}" FontSize="16" FontWeight="Bold" Foreground="#047857"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- ROW 4: STATUS BAR -->
        <!-- ============================================================ -->
        <Border Grid.Row="4" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1,0,1,1"
                CornerRadius="0,0,8,8" Padding="16,8">
            <Grid>
                <!-- Sales Overview status (Tab 0) — always shows date -->
                <TextBlock x:Name="StatusSales" Visibility="Visible" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                    <Run Text="Showing data for:"/>
                    <Run Text="{Binding SelectedDate, StringFormat='{}{0:dd MMM yyyy}', Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>

                <!-- Order History status (Tab 1) -->
                <StackPanel x:Name="StatusOrders" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Orders:"/>
                        <Run Text="{Binding OrderHistoryCount, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Total:"/>
                        <Run Text="{Binding OrderHistoryTotal, Mode=OneWay}" FontWeight="SemiBold" Foreground="#059669"/>
                    </TextBlock>
                </StackPanel>

                <!-- Menu Performance status (Tab 2) -->
                <StackPanel x:Name="StatusMenu" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Items Sold:"/>
                        <Run Text="{Binding MenuItemsSold, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Revenue:"/>
                        <Run Text="{Binding MenuRevenueTotal, Mode=OneWay}" FontWeight="SemiBold" Foreground="#059669"/>
                    </TextBlock>
                </StackPanel>

                <!-- Delivery Drivers status (Tab 3) -->
                <StackPanel x:Name="StatusDrivers" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Deliveries:"/>
                        <Run Text="{Binding TotalDeliveries, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Revenue:"/>
                        <Run Text="{Binding DriverRevenueTotal, Mode=OneWay}" FontWeight="SemiBold" Foreground="#059669"/>
                    </TextBlock>
                </StackPanel>

                <!-- Kitchen status (Tab 4) -->
                <TextBlock x:Name="StatusKitchen" Visibility="Collapsed" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                    <Run Text="Kitchen Orders:"/>
                    <Run Text="{Binding KitchenCount, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>

                <!-- Expenses status (Tab 5) -->
                <StackPanel x:Name="StatusExpenses" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Expenses:"/>
                        <Run Text="{Binding ExpenseCount, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Total:"/>
                        <Run Text="{Binding ExpenseTotal, Mode=OneWay}" FontWeight="SemiBold" Foreground="#DC2626"/>
                    </TextBlock>
                </StackPanel>

                <!-- Profit & Loss status (Tab 6) -->
                <StackPanel x:Name="StatusProfit" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Revenue:"/>
                        <Run Text="{Binding SummaryRevenue, Mode=OneWay}" FontWeight="SemiBold" Foreground="#059669"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Expenses:"/>
                        <Run Text="{Binding SummaryExpenses, Mode=OneWay}" FontWeight="SemiBold" Foreground="#DC2626"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Profit:"/>
                        <Run Text="{Binding SummaryProfit, Mode=OneWay}" FontWeight="SemiBold" Foreground="#2563EB"/>
                    </TextBlock>
                </StackPanel>

                <!-- Sales Report status (Tab 7) -->
                <StackPanel x:Name="StatusSalesReport" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Items:"/>
                        <Run Text="{Binding SalesReportCount, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Grand Total:"/>
                        <Run Text="{Binding SaleGrandTotal, Mode=OneWay}" FontWeight="SemiBold" Foreground="#059669"/>
                    </TextBlock>
                    <Border Width="1" Background="#D1D5DB" Margin="16,2"/>
                    <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center">
                        <Run Text="Cash In Hand:"/>
                        <Run Text="{Binding SaleCashInHand, Mode=OneWay}" FontWeight="SemiBold" Foreground="#047857"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
