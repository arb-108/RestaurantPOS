                              ItemsSource="{Binding ProfitLossItems}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F3F4F6" HeadersVisibility="Column"
                              AlternationCount="2" RowHeight="44" BorderThickness="0"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              RowStyle="{StaticResource DgRow}"
                              CellStyle="{StaticResource DgCell}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="PERIOD" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Period}" FontWeight="Bold" Foreground="#1E293B"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="REVENUE" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Revenue}"
                                                   Foreground="#059669" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
