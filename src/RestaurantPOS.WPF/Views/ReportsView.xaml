                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#10B981" CornerRadius="3" Height="20" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#374151" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
