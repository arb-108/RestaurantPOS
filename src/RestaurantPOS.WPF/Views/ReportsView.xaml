                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#F59E0B" CornerRadius="3" Height="20" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#374151" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- ======================================================== -->
                <!-- TAB 1: ORDER HISTORY -->
                <!-- ======================================================== -->
                <DataGrid x:Name="PanelOrders" Visibility="Collapsed"
                          ItemsSource="{Binding OrderHistoryItems}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6" HeadersVisibility="Column"
                          AlternationCount="2" RowHeight="44" BorderThickness="0"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          RowStyle="{StaticResource DgRow}"
                          CellStyle="{StaticResource DgCell}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="ORDER #" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="#1E293B"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="DATE" Binding="{Binding Date}" Width="150"/>
                        <DataGridTemplateColumn Header="TYPE" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E0E7FF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="DineIn">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="TakeAway">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Delivery">
                                                        <Setter Property="Background" Value="#FCE7F3"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3730A3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="DineIn">
                                                            <Setter Property="Foreground" Value="#1E40AF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="TakeAway">
                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Delivery">
                                                            <Setter Property="Foreground" Value="#9D174D"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="CUSTOMER" Binding="{Binding CustomerName}" Width="130"/>
                        <DataGridTextColumn Header="ITEMS" Binding="{Binding ItemCount}" Width="70"/>
                        <DataGridTemplateColumn Header="STATUS" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F3F4F6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Open">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Void">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                            <Setter Property="Foreground" Value="#166534"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Open">
                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Void">
                                                            <Setter Property="Foreground" Value="#991B1B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="TOTAL" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Total}"
                                               FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PAYMENT" Binding="{Binding PaymentMethod}" Width="100"/>
                        <DataGridTemplateColumn Header="ACTIONS" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RowBtn}" Background="#6366F1" Content="&#xE749;"
                                            ToolTip="Print Order"
                                            Command="{Binding DataContext.PrintOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ======================================================== -->
                <!-- TAB 2: MENU PERFORMANCE -->
                <!-- ======================================================== -->
                <DataGrid x:Name="PanelMenu" Visibility="Collapsed"
                          ItemsSource="{Binding MenuPerformanceItems}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6" HeadersVisibility="Column"
                          AlternationCount="2" RowHeight="44" BorderThickness="0"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          RowStyle="{StaticResource DgRow}"
                          CellStyle="{StaticResource DgCell}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="ITEM NAME" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ItemName}" FontWeight="Bold" Foreground="#1E293B"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="CATEGORY" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#DCFCE7" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="#166534"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="QTY SOLD" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding QtySold}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="REVENUE" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Revenue}"
                                               FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="AVG PRICE" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AvgPrice}"
                                               HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ======================================================== -->
                <!-- TAB 3: DELIVERY DRIVERS -->
                <!-- ======================================================== -->
                <DataGrid x:Name="PanelDrivers" Visibility="Collapsed"
                          ItemsSource="{Binding DriverPerformanceItems}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6" HeadersVisibility="Column"
                          AlternationCount="2" RowHeight="44" BorderThickness="0"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          RowStyle="{StaticResource DgRow}"
                          CellStyle="{StaticResource DgCell}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="DRIVER" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DriverName}" FontWeight="Bold" Foreground="#1E293B"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="130"/>
                        <DataGridTemplateColumn Header="ORDERS" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OrderCount}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="TOTAL REVENUE" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TotalRevenue}"
                                               FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="AVG/ORDER" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AvgPerOrder}"
                                               HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ======================================================== -->
                <!-- TAB 4: KITCHEN -->
                <!-- ======================================================== -->
                <DataGrid x:Name="PanelKitchen" Visibility="Collapsed"
                          ItemsSource="{Binding KitchenItems}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6" HeadersVisibility="Column"
                          AlternationCount="2" RowHeight="44" BorderThickness="0"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          RowStyle="{StaticResource DgRow}"
                          CellStyle="{StaticResource DgCell}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="ORDER #" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="#1E293B"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="DATE" Binding="{Binding Date}" Width="150"/>
                        <DataGridTemplateColumn Header="STATION" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E0E7FF" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Station}" FontSize="10" FontWeight="Bold" Foreground="#3730A3"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="ITEMS" Binding="{Binding ItemsSummary}" Width="*"/>
                        <DataGridTemplateColumn Header="ITEM COUNT" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ItemCount}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="STATUS" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F3F4F6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Background" Value="#E0E7FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="#166534"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Foreground" Value="#3730A3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ======================================================== -->
                <!-- TAB 5: EXPENSES -->
                <!-- ======================================================== -->
                <DataGrid x:Name="PanelExpenses" Visibility="Collapsed"
                          ItemsSource="{Binding ExpenseItems}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6" HeadersVisibility="Column"
                          AlternationCount="2" RowHeight="44" BorderThickness="0"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          RowStyle="{StaticResource DgRow}"
                          CellStyle="{StaticResource DgCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat='{}{0:dd MMM yyyy}'}" Width="120"/>
                        <DataGridTemplateColumn Header="SUPPLIER" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Supplier}" FontWeight="Bold" Foreground="#1E293B"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="200"/>
                        <DataGridTemplateColumn Header="CATEGORY" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E0E7FF" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="#3730A3"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="AMOUNT" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Amount}"
                                               FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="STATUS" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F3F4F6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Unpaid">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                            <Setter Property="Foreground" Value="#166534"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Unpaid">
                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ======================================================== -->
                <!-- TAB 6: PROFIT & LOSS -->
                <!-- ======================================================== -->
                <Grid x:Name="PanelProfit" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- P&L Summary Cards -->
                    <UniformGrid Grid.Row="0" Columns="4" Margin="16,16,16,8">
                        <!-- Total Revenue -->
                        <Border Background="#F0FDF4" CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Total Revenue" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SummaryRevenue}"
                                           FontSize="24" FontWeight="Bold" Foreground="#059669"/>
                            </StackPanel>
                        </Border>
                        <!-- Total Expenses -->
                        <Border Background="#FEF2F2" CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Total Expenses" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SummaryExpenses}"
                                           FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                        <!-- Net Profit -->
                        <Border CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Net Profit" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SummaryProfit}"
                                           FontSize="24" FontWeight="Bold" Foreground="#2563EB"/>
                            </StackPanel>
                        </Border>
                        <!-- Margin -->
                        <Border Background="#F5F3FF" CornerRadius="10" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="Margin" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SummaryMargin}" FontSize="24" FontWeight="Bold" Foreground="#7C3AED"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- P&L DataGrid -->
