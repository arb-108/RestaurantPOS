<UserControl x:Class="RestaurantPOS.WPF.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PrimaryBgBrush}"
             FontFamily="{StaticResource AppFont}"
             Loaded="OnLoaded">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Date Picker Row -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="REPORTS DASHBOARD" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Date:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker SelectedDate="{Binding SelectedDate}" Width="140"/>
            </StackPanel>
        </Border>

        <!-- Summary Cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,8">
            <!-- Total Sales -->
            <Border Background="White" CornerRadius="6" Padding="16,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Sales" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalSales}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
            <!-- Total Orders -->
            <Border Background="White" CornerRadius="6" Padding="16,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Orders" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalOrders}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TableGreenBrush}"/>
                </StackPanel>
            </Border>
            <!-- Avg Order Value -->
            <Border Background="White" CornerRadius="6" Padding="16,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Avg Order Value" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvgOrderValue}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WarningBrush}"/>
                </StackPanel>
            </Border>
            <!-- Voided Orders -->
            <Border Background="White" CornerRadius="6" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Voided" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding VoidedOrders}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Charts Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sales by Category (Bar Chart) -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Sales by Category" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SalesByCategory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{StaticResource AccentBrush}" CornerRadius="2"
                                                    Height="20" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}" FontSize="11"
                                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Sales by Hour -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Sales by Hour" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SalesByHour}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{StaticResource TableGreenBrush}" CornerRadius="2"
                                                    Height="20" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}" FontSize="11"
                                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Sales by Payment Method -->
            <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Sales by Payment Method" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                    <!-- Payment summary cards -->
                    <StackPanel Grid.Row="1">
                        <Border Background="#E8F5E9" CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="Cash" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CashSales}" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Right" Foreground="{StaticResource TableGreenBrush}"/>
                            </Grid>
                        </Border>
                        <Border Background="#E3F2FD" CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="Card" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CardSales}" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}"/>
                            </Grid>
                        </Border>
                        <Border Background="#FFF3E0" CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="Digital" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding DigitalSales}" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Right" Foreground="{StaticResource WarningBrush}"/>
                            </Grid>
                        </Border>

                        <Border Height="1" Background="#E0E0E0" Margin="0,8"/>

                        <TextBlock Margin="0,4,0,0">
                            <Run Text="Peak Hour: " FontWeight="SemiBold"/>
                            <Run Text="{Binding PeakHour, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- Bar chart for payment methods -->
                        <ItemsControl ItemsSource="{Binding SalesByPaymentMethod}" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{StaticResource WarningBrush}" CornerRadius="2"
                                                    Height="20" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}" FontSize="11"
                                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
