<UserControl x:Class="RestaurantPOS.WPF.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RestaurantPOS.WPF.Converters"
             Background="#F0F2F5" FontFamily="Segoe UI" Loaded="OnLoaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:PaisaToCurrencyConverter x:Key="PaisaToCurrency"/>

        <!-- Action button -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/><Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.85"/></Trigger>
                    <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.75"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- Row action button -->
        <Style x:Key="RowBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/><Setter Property="Height" Value="28"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Width="28" Height="28">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- Filter combo -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/><Setter Property="Height" Value="30"/><Setter Property="MinWidth" Value="110"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- FolderTab style -->
        <Style x:Key="FolderTab" TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="0,0,-4,0"/>
            <Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid x:Name="TabRoot" Margin="0,0,0,-1" Height="35">
                        <Border x:Name="TabShape" CornerRadius="3,3,0,0" Margin="3,2,3,0">
                            <Border.Background><SolidColorBrush Color="#283593"/></Border.Background>
                        </Border>
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,6"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabShape" Property="Background" Value="#D5D9DD"/>
                            <Setter TargetName="TabShape" Property="BorderBrush" Value="#B0B8BF"/>
                            <Setter TargetName="TabShape" Property="BorderThickness" Value="1,1,1,0"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter TargetName="TabRoot" Property="Panel.ZIndex" Value="10"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter TargetName="TabShape" Property="Background" Value="#283593"/>
                            <Setter TargetName="TabShape" Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabShape" Property="Background" Value="#3949AB"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value></Setter>
        </Style>

        <!-- DataGrid styles -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/><Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/><Setter Property="BorderBrush" Value="#E5E7EB"/><Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1"><Setter Property="Background" Value="#FAFBFC"/></Trigger>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#EBF5FF"/></Trigger>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F0F7FF"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="14,0"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="DataGridCell">
                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter VerticalAlignment="Center"/></Border>
            </ControlTemplate></Setter.Value></Setter>
            <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#111827"/></Trigger></Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Tabs -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Filter/Action bar -->
            <RowDefinition Height="*"/>     <!-- Row 3: Content -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- ROW 0: HEADER -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Background="White" CornerRadius="8,8,0,0" Padding="16,12" Margin="0,0,0,0">
            <TextBlock Text="REPORTS &amp; ANALYTICS" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
        </Border>

        <!-- ============================================================ -->
        <!-- ROW 1: TAB CONTROL -->
        <!-- ============================================================ -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Background="#D5D9DD" BorderThickness="0"
                    Padding="0" Margin="0" SelectionChanged="TabChanged">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="0"/>
                        </Grid.RowDefinitions>
                        <Border Background="#283593" Padding="4,0,4,0">
                            <TabPanel IsItemsHost="True"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Sales Overview" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Order History" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Menu Performance" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Delivery Drivers" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Kitchen" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Expenses" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Profit &amp; Loss" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Sales Report" Style="{StaticResource FolderTab}"/>
        </TabControl>

        <!-- ============================================================ -->
        <!-- ROW 2: FILTER / ACTION BAR -->
        <!-- ============================================================ -->
        <Border Grid.Row="2" Background="#D5D9DD" BorderBrush="#B0B8BF" BorderThickness="1,0,1,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- FILTER PANELS (stacked, only one visible at a time) -->
                <Grid Grid.Column="0">

                    <!-- Tab 0: Sales Overview filters -->
                    <StackPanel x:Name="FilterSales" Orientation="Horizontal" Visibility="Visible">
                        <TextBlock Text="Date:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding SelectedDate}" FontSize="12" Height="30" Width="140"/>
                    </StackPanel>

                    <!-- Tab 1: Order History filters -->
                    <StackPanel x:Name="FilterOrders" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="From:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding OrdersFrom}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="To:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding OrdersTo}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="Type:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding OrderTypeOptions}"
                                  SelectedItem="{Binding OrderTypeFilter}" Margin="0,0,12,0"/>
                        <TextBlock Text="Status:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding OrderStatusOptions}"
                                  SelectedItem="{Binding OrderStatusFilter}" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Tab 2: Menu Performance filters -->
                    <StackPanel x:Name="FilterMenu" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="From:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding MenuFrom}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="To:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding MenuTo}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="Category:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding MenuCategoryOptions}"
                                  SelectedItem="{Binding MenuCategoryFilter}" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Tab 3: Delivery Drivers filters -->
                    <StackPanel x:Name="FilterDrivers" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="From:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding DriverFrom}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="To:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding DriverTo}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Tab 4: Kitchen filters -->
                    <StackPanel x:Name="FilterKitchen" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="From:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding KitchenFrom}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="To:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding KitchenTo}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Tab 5: Expenses filters -->
                    <StackPanel x:Name="FilterExpenses" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="From:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding ExpenseFrom}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="To:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding ExpenseTo}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="Category:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding ExpenseCategoryOptions}"
                                  SelectedItem="{Binding ExpenseCategoryFilter}" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Tab 6: Profit & Loss filters -->
                    <StackPanel x:Name="FilterProfit" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="From:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding ProfitFrom}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="To:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding ProfitTo}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="Period:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding ProfitPeriodOptions}"
                                  SelectedItem="{Binding ProfitPeriod}" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Tab 7: Sales Report filters -->
                    <StackPanel x:Name="FilterSalesReport" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="From:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding SalesReportFrom}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="To:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding SalesReportTo}" FontSize="12" Height="30" Width="130" Margin="0,0,12,0"/>
                        <TextBlock Text="Mode:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding SalesReportModeOptions}"
                                  SelectedItem="{Binding SalesReportMode}" Margin="0,0,12,0"/>
                        <TextBlock Text="Category:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Style="{StaticResource FilterCombo}" ItemsSource="{Binding SalesReportCategories}"
                                  SelectedItem="{Binding SalesReportCategory}" MinWidth="140"/>
                    </StackPanel>
                </Grid>

                <!-- ACTION BUTTON PANELS -->
                <Grid Grid.Column="1">

                    <!-- Tab 0: Sales buttons -->
                    <StackPanel x:Name="BtnSales" Orientation="Horizontal" Visibility="Visible">
                        <Button Style="{StaticResource Btn}" Background="#2563EB" Content="Refresh"
                                Command="{Binding LoadDataCommand}" Margin="0,0,6,0"/>
                    </StackPanel>

                    <!-- Tab 1: Order History buttons -->
                    <StackPanel x:Name="BtnOrders" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Style="{StaticResource Btn}" Background="#2563EB" Command="{Binding LoadOrderHistoryCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Load"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Tab 2: Menu Performance buttons -->
                    <StackPanel x:Name="BtnMenu" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Style="{StaticResource Btn}" Background="#059669" Command="{Binding LoadMenuPerformanceCommand}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Load"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Btn}" Background="#6366F1" Command="{Binding PrintMenuReportCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Print Report"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Tab 3: Delivery Drivers buttons -->
                    <StackPanel x:Name="BtnDrivers" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Style="{StaticResource Btn}" Background="#4F46E5" Command="{Binding LoadDriverPerformanceCommand}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Load"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Btn}" Background="#6366F1" Command="{Binding PrintDriverReportCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Print Report"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Tab 4: Kitchen buttons -->
                    <StackPanel x:Name="BtnKitchen" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Style="{StaticResource Btn}" Background="#EA580C" Command="{Binding LoadKitchenCommand}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Load"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Btn}" Background="#6366F1" Command="{Binding PrintKitchenReportCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Print Report"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Tab 5: Expenses buttons -->
                    <StackPanel x:Name="BtnExpenses" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Style="{StaticResource Btn}" Background="#DC2626" Command="{Binding LoadExpensesCommand}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Load"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Btn}" Background="#6366F1" Command="{Binding PrintExpenseReportCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Print Report"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Tab 6: Profit & Loss buttons -->
                    <StackPanel x:Name="BtnProfit" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Style="{StaticResource Btn}" Background="#7C3AED" Command="{Binding LoadProfitLossCommand}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Load"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Btn}" Background="#6366F1" Command="{Binding PrintProfitLossCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Print Report"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Tab 7: Sales Report buttons -->
                    <StackPanel x:Name="BtnSalesReport" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Style="{StaticResource Btn}" Background="#0891B2" Command="{Binding LoadSalesReportCommand}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Load"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Btn}" Background="#6366F1" Command="{Binding PrintSalesReportCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Print Report"/></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- ROW 3: CONTENT PANELS -->
        <!-- ============================================================ -->
        <Border Grid.Row="3" Background="White" BorderBrush="#B0B8BF" BorderThickness="1,0,1,1" ClipToBounds="True">
            <Grid>

                <!-- ======================================================== -->
                <!-- TAB 0: SALES OVERVIEW (Dashboard — no DataGrid) -->
                <!-- ======================================================== -->
                <ScrollViewer x:Name="PanelSales" VerticalScrollBarVisibility="Auto" Visibility="Visible" Padding="16">
                    <StackPanel>

                        <!-- Summary Cards Row -->
                        <UniformGrid Columns="4" Margin="0,0,0,16">
                            <!-- Total Sales -->
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Total Sales" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding TotalSales}" FontSize="26" FontWeight="Bold" Foreground="#2563EB"/>
                                </StackPanel>
                            </Border>
                            <!-- Total Orders -->
                            <Border Background="#F0FDF4" CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Total Orders" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding TotalOrders}" FontSize="26" FontWeight="Bold" Foreground="#059669"/>
                                </StackPanel>
                            </Border>
                            <!-- Avg Order Value -->
                            <Border Background="#FFFBEB" CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Avg Order Value" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding AvgOrderValue}" FontSize="26" FontWeight="Bold" Foreground="#D97706"/>
                                </StackPanel>
                            </Border>
                            <!-- Voided Orders -->
                            <Border Background="#FEF2F2" CornerRadius="10" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="Voided" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding VoidedOrders}" FontSize="26" FontWeight="Bold" Foreground="#DC2626"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Payment Breakdown Row -->
                        <UniformGrid Columns="4" Margin="0,0,0,16">
                            <!-- Cash Sales -->
                            <Border Background="#E8F5E9" CornerRadius="10" Padding="16,12" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Cash Sales" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CashSales}" FontSize="20" FontWeight="Bold" Foreground="#2E7D32"/>
                                </StackPanel>
                            </Border>
                            <!-- Card Sales -->
                            <Border Background="#E3F2FD" CornerRadius="10" Padding="16,12" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Card Sales" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CardSales}" FontSize="20" FontWeight="Bold" Foreground="#1565C0"/>
                                </StackPanel>
                            </Border>
                            <!-- Digital Sales -->
                            <Border Background="#FFF3E0" CornerRadius="10" Padding="16,12" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Digital Sales" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding DigitalSales}" FontSize="20" FontWeight="Bold" Foreground="#E65100"/>
                                </StackPanel>
                            </Border>
                            <!-- Peak Hour -->
                            <Border Background="#F3E5F5" CornerRadius="10" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="Peak Hour" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding PeakHour}" FontSize="20" FontWeight="Bold" Foreground="#7B1FA2"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Charts Row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Sales by Category chart -->
                            <Border Grid.Column="0" Background="#FAFBFC" CornerRadius="10" Padding="14" Margin="0,0,10,0" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Sales by Category" FontSize="14" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding SalesByCategory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,3">
                                                    <TextBlock Text="{Binding Label}" FontSize="11" Foreground="#6B7280"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#3B82F6" CornerRadius="3" Height="20" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#374151" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Sales by Hour chart -->
