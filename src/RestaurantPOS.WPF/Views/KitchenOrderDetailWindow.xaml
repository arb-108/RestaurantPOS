<Window x:Class="RestaurantPOS.WPF.Views.KitchenOrderDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kitchen Order Detail" Width="700" Height="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8FAFC" WindowStyle="SingleBorderWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Order Info -->
        <Border Grid.Row="0" Background="#EFF6FF" CornerRadius="6" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Order #" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="OrderNum" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Type" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="OrderType" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Date / Time" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="OrderDate" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Status" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="OrderStatus" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                    <TextBlock Text="Cashier" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="CashierName" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                    <TextBlock Text="Table" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="TableName" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                    <TextBlock Text="Total Items" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="TotalItems" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,8,0,0">
                    <TextBlock Text="Kitchen Slips" FontSize="10" Foreground="#6B7280"/>
                    <TextBlock x:Name="SlipCount" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Section header -->
        <TextBlock Grid.Row="1" Text="Kitchen Slips &amp; Items" FontSize="13" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,6"/>

        <!-- Slips list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SlipsPanel"/>
        </ScrollViewer>

        <!-- Close button -->
        <Button Grid.Row="3" Content="Close" FontSize="13" Padding="24,8" HorizontalAlignment="Right" Margin="0,10,0,0"
                Background="#475569" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Close_Click"/>
    </Grid>
</Window>
