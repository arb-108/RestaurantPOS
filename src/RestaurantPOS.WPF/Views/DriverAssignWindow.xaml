<Window x:Class="RestaurantPOS.WPF.Views.DriverAssignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Delivery Driver"
        Height="520" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Rounded TextBox style -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="6" Background="#F5F7FA" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Add New Driver -->
                <RowDefinition Height="Auto"/>  <!-- Search -->
                <RowDefinition Height="*"/>     <!-- Driver List -->
                <RowDefinition Height="Auto"/>  <!-- Bottom Buttons -->
            </Grid.RowDefinitions>

            <!-- ═══ Row 0: Header bar ═══ -->

            <!-- ═══ Row 1: Add New Driver (Admin/Manager only) ═══ -->
            <Border x:Name="AddDriverPanel" Grid.Row="1" Visibility="Collapsed"
                    Background="White" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="#E5E7EB">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="#1565C0"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Add New Driver" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Row 1: Labels -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Driver Name" FontSize="11" Foreground="#64748B" Margin="2,0,0,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Mobile No." FontSize="11" Foreground="#64748B" Margin="2,0,0,0"/>
                        <!-- Row 2: Inputs -->
                        <TextBox x:Name="TxtNewName" Grid.Row="2" Grid.Column="0"
                                 Style="{StaticResource RoundedTextBox}"/>
                        <TextBox x:Name="TxtNewPhone" Grid.Row="2" Grid.Column="2"
                                 Style="{StaticResource RoundedTextBox}"/>
                        <Button Grid.Row="2" Grid.Column="4" Content="+ Add" Click="AddDriver_Click"
                                Width="72" Background="#4CAF50"
                                Style="{StaticResource ActionButton}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Row 2: Search ═══ -->
            <Border Grid.Row="2" Background="White" Padding="16,10" BorderThickness="0,0,0,1" BorderBrush="#E5E7EB">
                <Grid>
                    <TextBox x:Name="TxtSearch" Style="{StaticResource RoundedTextBox}"
                             Padding="32,7,10,7"
                             TextChanged="Search_TextChanged"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="#94A3B8"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               IsHitTestVisible="False"/>
                    <TextBlock x:Name="TxtSearchHint" Text="Search by name or Phone"
                               FontSize="13" Foreground="#94A3B8"
                               VerticalAlignment="Center" Margin="34,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- ═══ Row 3: Driver List ═══ -->
            <ListBox x:Name="LstDrivers" Grid.Row="3" BorderThickness="0"
                     SelectionChanged="DriverList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Background="White" Margin="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent"
                                            Padding="{TemplateBinding Padding}"
                                            BorderThickness="0,0,0,1" BorderBrush="#F0F0F0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F0F7FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#1565C0"/>
                                            <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Avatar circle -->
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19"
                                    Background="#1565C0" Margin="0,0,12,0">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="17" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Name & Phone -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           FontSize="14" Foreground="#1E293B"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#64748B"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Phone}" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Green dot -->
                            <Border Grid.Column="2" Width="10" Height="10" CornerRadius="5"
                                    Background="#4CAF50" VerticalAlignment="Center"
                                    ToolTip="Available"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ═══ Row 4: Bottom bar ═══ -->
            <Border Grid.Row="4" Background="#F8FAFC" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="#E5E7EB">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Driver count -->
                    <TextBlock x:Name="TxtDriverCount" Grid.Column="0"
                               FontSize="12" Foreground="#94A3B8"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="Cancel" Click="Cancel_Click"
                            Width="100" Background="#94A3B8"
                            Style="{StaticResource ActionButton}"/>

                    <Button Grid.Column="3" Content="Assign Driver" Click="Assign_Click"
                            Width="130" Background="#4CAF50"
                            Style="{StaticResource ActionButton}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
