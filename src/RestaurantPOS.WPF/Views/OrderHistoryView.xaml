<UserControl x:Class="RestaurantPOS.WPF.Views.OrderHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RestaurantPOS.WPF.Converters"
             Background="{StaticResource PrimaryBgBrush}"
             FontFamily="{StaticResource AppFont}"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:PaisaToCurrencyConverter x:Key="PaisaToCurrency"/>

        <!-- Filter-bar chip button (outlined) -->
        <Style x:Key="FilterChipButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="BorderBrush" Value="#1565C0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary solid button -->
        <Style x:Key="PrimarySolidButton" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D47A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row action button (small, in datagrid) -->
        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D47A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Filter ComboBox -->
        <Style x:Key="FilterComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <!-- Filter DatePicker -->
        <Style x:Key="FilterDatePicker" TargetType="DatePicker">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Filter TextBox -->
        <Style x:Key="FilterTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ FILTER BAR ═══ -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="14,12" Margin="0,0,0,8">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="6" ShadowDepth="1" Opacity="0.25"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Date -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Date" FontSize="10" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,3"/>
                    <DatePicker Style="{StaticResource FilterDatePicker}"
                                SelectedDate="{Binding FromDate}" Width="140"/>
                </StackPanel>

                <!-- Show All Toggle -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Text="Scope" FontSize="10" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,3"/>
                    <Button Content="{Binding ShowAllLabel}"
                            Command="{Binding ToggleShowAllCommand}"
                            Style="{StaticResource FilterChipButton}" Width="150" Height="30"/>
                </StackPanel>

                <!-- Order Type Filter -->
                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Type" FontSize="10" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,3"/>
                    <ComboBox Style="{StaticResource FilterComboBox}" Width="120"
                              ItemsSource="{Binding OrderTypeFilters}"
                              SelectedItem="{Binding SelectedOrderTypeFilter}"/>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Grid.Column="3" Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Text="Status" FontSize="10" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,3"/>
                    <ComboBox Style="{StaticResource FilterComboBox}" Width="110"
                              ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding SelectedStatusFilter}"/>
                </StackPanel>

                <!-- Search -->
                <StackPanel Grid.Column="4" Orientation="Vertical" Margin="0,0,12,0" MinWidth="260">
                    <TextBlock Text="Search" FontSize="10" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,3"/>
                    <TextBox Style="{StaticResource FilterTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                             ToolTip="Search by order number, customer name or phone"/>
                </StackPanel>

                <!-- Refresh -->
                <Button Grid.Column="5" Content="Refresh"
                        Style="{StaticResource PrimarySolidButton}"
                        Command="{Binding SearchOrdersCommand}"
                        Width="100" Height="30" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- ═══ SUMMARY STRIP ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Count card -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="14,10" Margin="0,0,4,0">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Total Orders" FontSize="11" Foreground="#666" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ResultCount}" FontSize="20" FontWeight="Bold" Foreground="#1A237E"/>
                </StackPanel>
            </Border>
            <!-- Revenue card -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="14,10" Margin="4,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Revenue (excl. voids)" FontSize="11" Foreground="#666" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalRevenue, Converter={StaticResource PaisaToCurrency}}"
                               FontSize="20" FontWeight="Bold" Foreground="#2E7D32"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ ORDERS DATAGRID ═══ -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="0" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="6" ShadowDepth="1" Opacity="0.25"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Orders}"
                      SelectedItem="{Binding SelectedOrder}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      RowHeight="36"
                      FontSize="12"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#E0E0E0"
                      VirtualizingPanel.IsVirtualizing="True">

                <!-- Header Style -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1565C0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,10"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="BorderBrush" Value="#1976D2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- Cell Style -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <!-- Row Style (hover) -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order #" Binding="{Binding OrderNumber}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1A237E"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Type" Binding="{Binding OrderType}" Width="100"/>

                    <!-- Status with colored text -->
                    <DataGridTemplateColumn Header="Status" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Open">
                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Void">
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Preparing">
                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                    <Setter Property="Foreground" Value="#6A1B9A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="160"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Customer.Phone}" Width="120"/>
                    <DataGridTextColumn Header="Items" Binding="{Binding OrderItems.Count}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Total"
                                        Binding="{Binding GrandTotal, Converter={StaticResource PaisaToCurrency}}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#2E7D32"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Cashier" Binding="{Binding Cashier.FullName}" Width="130"/>
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy hh:mm tt}'}"
                                        Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#555"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Receipt reprint -->
                    <DataGridTemplateColumn Header="Receipt" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Receipt"
                                        Style="{StaticResource RowActionButton}"
                                        Command="{Binding DataContext.ShowReceiptCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Reprint receipt"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ═══ FOOTER BAR ═══ -->
        <Border Grid.Row="3" Background="#E8EAF6" CornerRadius="4" Padding="12,6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" FontWeight="SemiBold" Foreground="#1A237E"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
