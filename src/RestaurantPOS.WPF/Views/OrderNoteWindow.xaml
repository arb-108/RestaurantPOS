<Window x:Class="RestaurantPOS.WPF.Views.OrderNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order Note"
        Height="300" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#DAEDF4"
        FontFamily="Segoe UI">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets"
                       FontSize="24" Foreground="#FF9800"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Order Note / Instructions"
                       FontSize="16" FontWeight="Bold" Foreground="#333"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Label -->
        <TextBlock Grid.Row="1" FontSize="13" Foreground="#666" Margin="0,0,0,6"
                   Text="Add customer instructions or internal staff reminders:"/>

        <!-- Note TextBox -->
        <TextBox x:Name="TxtNote" Grid.Row="2" FontSize="14" Padding="8,6"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top"
                 BorderBrush="#999" BorderThickness="1"
                 Margin="0,0,0,14"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click"
                    Width="100" Height="36" FontSize="14" FontWeight="Bold"
                    Foreground="White" Cursor="Hand" Margin="0,0,10,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#9E9E9E" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Save Note" Click="Save_Click"
                    Width="110" Height="36" FontSize="14" FontWeight="Bold"
                    Foreground="White" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#FF9800" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
