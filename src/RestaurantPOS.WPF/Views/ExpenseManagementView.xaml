<UserControl x:Class="RestaurantPOS.WPF.Views.ExpenseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RestaurantPOS.WPF.Converters"
             Background="#F0F2F5" FontFamily="Segoe UI" Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:PaisaToCurrencyConverter x:Key="PaisaToCurrency"/>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/><Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.85"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="RowBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/><Setter Property="Height" Value="28"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Width="28" Height="28">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/><Setter Property="Height" Value="30"/><Setter Property="MinWidth" Value="110"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- POS Folder Tab Style -->
        <Style x:Key="FolderTab" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,-4,0"/>
            <Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid x:Name="TabRoot" Margin="0,0,0,-1" Height="35">
                        <Border x:Name="TabShape" CornerRadius="3,3,0,0" Margin="3,2,3,0">
                            <Border.Background><SolidColorBrush Color="#283593"/></Border.Background>
                        </Border>
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,6"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabShape" Property="Background" Value="#D5D9DD"/>
                            <Setter TargetName="TabShape" Property="BorderBrush" Value="#B0B8BF"/>
                            <Setter TargetName="TabShape" Property="BorderThickness" Value="1,1,1,0"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter TargetName="TabRoot" Property="Panel.ZIndex" Value="10"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter TargetName="TabShape" Property="Background" Value="#283593"/>
                            <Setter TargetName="TabShape" Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabShape" Property="Background" Value="#3949AB"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value></Setter>
        </Style>

        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/><Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/><Setter Property="BorderBrush" Value="#E5E7EB"/><Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1"><Setter Property="Background" Value="#FAFBFC"/></Trigger>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#EBF5FF"/></Trigger>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F0F7FF"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="14,0"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="DataGridCell">
                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter VerticalAlignment="Center"/></Border>
            </ControlTemplate></Setter.Value></Setter>
            <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#111827"/></Trigger></Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Tabs -->
            <RowDefinition Height="Auto"/>  <!-- Filter/Action -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- HEADER BAR -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,12" Margin="0,0,0,10">
            <Border.Effect><DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.04" Color="#000"/></Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Expense Management" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Track suppliers and expenses" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" Background="#6366F1" Style="{StaticResource Btn}" Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Refresh"/></StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- TABS -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" SelectedIndex="0" Background="Transparent"
                    BorderThickness="0" Padding="0" Margin="0,0,0,0"
                    SelectionChanged="TabChanged">
            <TabItem Header="Suppliers" Style="{StaticResource FolderTab}"/>
            <TabItem Header="Expenses" Style="{StaticResource FolderTab}"/>
        </TabControl>

        <!-- FILTER + ACTION BAR (below tabs) -->
        <Border Grid.Row="2" Background="White" CornerRadius="0" Padding="16,10" Margin="0,0,0,0" BorderBrush="#E5E7EB" BorderThickness="1,0,1,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Filters -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F3F4F6" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1" MinWidth="240" Margin="0,0,12,0">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox Grid.Column="1" Text="{Binding SupplierSearch, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Height="30" Padding="4,4" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="LblSupplierFilter" Text="Supplier" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="CmbSupplierFilter" Style="{StaticResource FilterCombo}" MinWidth="140" ItemsSource="{Binding ExpenseFilterSuppliers}" SelectedItem="{Binding ExpenseFilterSupplier}" DisplayMemberPath="Name"/>
                </StackPanel>
                <!-- Action Buttons -->
                <StackPanel x:Name="BtnSuppliers" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Background="#059669" Style="{StaticResource Btn}" Command="{Binding AddSupplierCommand}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Add Supplier"/></StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel x:Name="BtnExpenses" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed">
                    <Button Background="#D97706" Style="{StaticResource Btn}" Command="{Binding AddExpenseCommand}">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Add Expense"/></StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT PANELS -->
        <Grid Grid.Row="3">
            <!-- Suppliers Panel -->
            <Border x:Name="PanelSuppliers" Background="White" CornerRadius="0,0,12,12" BorderBrush="#E5E7EB" BorderThickness="1" ClipToBounds="True">
                <DataGrid ItemsSource="{Binding Suppliers}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              GridLinesVisibility="None" BorderThickness="0" FontSize="12" RowHeight="40"
                              HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" AlternationCount="2"
                              ColumnHeaderStyle="{StaticResource DgHeader}" RowStyle="{StaticResource DgRow}" CellStyle="{StaticResource DgCell}"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Background="#2196F3" Style="{StaticResource RowBtn}" Content="&#xE70F;"
                    Command="{Binding DataContext.EditSupplierCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                        <Button Background="#DC2626" Style="{StaticResource RowBtn}" Content="&#xE74D;"
                    Command="{Binding DataContext.DeleteSupplierCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="auto">
                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#111827"/></Style></DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="CONTACT" Binding="{Binding ContactPerson}" Width="auto"/>
                            <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="auto"/>
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="auto"/>
                            <DataGridTextColumn Header="CITY" Binding="{Binding City}" Width="auto"/>
                            
                        </DataGrid.Columns>
                    </DataGrid>
            </Border>

            <!-- Expenses Panel -->
            <Border x:Name="PanelExpenses" Background="White" CornerRadius="0,0,12,12" BorderBrush="#E5E7EB" BorderThickness="1" ClipToBounds="True" Visibility="Collapsed">
                <DataGrid ItemsSource="{Binding Expenses}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              GridLinesVisibility="None" BorderThickness="0" FontSize="12" RowHeight="40"
                              HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" AlternationCount="2"
                              ColumnHeaderStyle="{StaticResource DgHeader}" RowStyle="{StaticResource DgRow}" CellStyle="{StaticResource DgCell}"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Background="#DC2626" Style="{StaticResource RowBtn}" Content="&#xE74D;"
                Command="{Binding DataContext.DeleteExpenseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="SUPPLIER" Binding="{Binding Supplier.Name}" Width="auto">
                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#111827"/></Style></DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="auto"/>
                            <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, Converter={StaticResource PaisaToCurrency}}" Width="auto">
                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#DC2626"/></Style></DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="INVOICE #" Binding="{Binding InvoiceNumber}" Width="auto"/>
                            <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}" Width="auto"/>
                            <DataGridTemplateColumn Header="PAID" Width="auto">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Center">
                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#DCFCE7"/>
                                            <Style.Triggers><DataTrigger Binding="{Binding IsPaid}" Value="False"><Setter Property="Background" Value="#FEF3C7"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold" HorizontalAlignment="Center">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Paid"/><Setter Property="Foreground" Value="#166534"/>
                                                <Style.Triggers><DataTrigger Binding="{Binding IsPaid}" Value="False"><Setter Property="Text" Value="Unpaid"/><Setter Property="Foreground" Value="#92400E"/></DataTrigger></Style.Triggers>
                                            </Style></TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                        </DataGrid.Columns>
                    </DataGrid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="4" Background="White" CornerRadius="10" Padding="16,8" Margin="0,10,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#475569" Margin="0,0,16,0" VerticalAlignment="Center"><Run Text="Total: "/><Run Text="{Binding ExpenseCountText, Mode=OneWay}" FontWeight="SemiBold"/></TextBlock>
                <TextBlock Grid.Column="2" FontSize="11" FontWeight="Bold" Foreground="#DC2626" VerticalAlignment="Center"><Run Text="Sum: "/><Run Text="{Binding TotalExpenseText, Mode=OneWay}"/></TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
