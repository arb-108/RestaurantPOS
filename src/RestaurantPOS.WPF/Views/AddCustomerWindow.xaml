<Window x:Class="RestaurantPOS.WPF.Views.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Customer"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#E9F3F8"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="8" Padding="18" 
                BorderBrush="#DFE9EE" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16" Foreground="#333">
                        <Run Text="Name:"/><Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox x:Name="TxtName" Grid.Column="1" FontSize="16" Height="38" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" TabIndex="0"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16" Foreground="#333">
                        <Run Text="Mobile:"/><Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox x:Name="TxtMobile" Grid.Column="1" FontSize="16" Height="38" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" TabIndex="1" MaxLength="15"/>
                </Grid>

                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16" Foreground="#333">Email:</TextBlock>
                    <TextBox x:Name="TxtEmail" Grid.Column="1" FontSize="16" Height="38" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" TabIndex="2"/>
                </Grid>

                <Grid Grid.Row="4" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Top" FontSize="16" Foreground="#333">
                        <Run Text="Address:"/><Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox x:Name="TxtAddress" Grid.Column="1" FontSize="14" Padding="8,6"
                             Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" BorderBrush="#CCD6DB" BorderThickness="1" TabIndex="3"/>
                </Grid>

                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button x:Name="BtnCancel" Content="Cancel" Click="Cancel_Click" Width="110" Height="38" Margin="0,0,10,0"
                            Background="#F44336" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" IsCancel="True" TabIndex="5">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.9"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="BtnSave" Content="Save" Click="Save_Click" Width="110" Height="38"
                            Background="#2E7D32" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" IsDefault="True" TabIndex="4">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.9"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
