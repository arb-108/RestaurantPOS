<Window x:Class="RestaurantPOS.WPF.Views.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Customer"
        Height="380" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Border Background="White" Padding="20,16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Name -->
            <TextBlock Grid.Row="0" VerticalAlignment="Center" FontSize="13" Foreground="#333">
                <Run Text="Name"/><Run Text="*" Foreground="Red"/>
            </TextBlock>
            <TextBox x:Name="TxtName" Grid.Row="0" Grid.Column="1" FontSize="13" Height="30" Padding="8,3"
                     VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,0,0,6"/>

            <!-- Mobile -->
            <TextBlock Grid.Row="1" VerticalAlignment="Center" FontSize="13" Foreground="#333">
                <Run Text="Mobile"/><Run Text="*" Foreground="Red"/>
            </TextBlock>
            <TextBox x:Name="TxtMobile" Grid.Row="1" Grid.Column="1" FontSize="13" Height="30" Padding="8,3"
                     VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1"
                     Foreground="Green" FontWeight="SemiBold" MaxLength="15" Margin="0,0,0,6"/>

            <!-- Email -->
            <TextBlock Grid.Row="2" VerticalAlignment="Center" FontSize="13" Foreground="#333">Email</TextBlock>
            <TextBox x:Name="TxtEmail" Grid.Row="2" Grid.Column="1" FontSize="13" Height="30" Padding="8,3"
                     VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,0,0,6"/>

            <!-- Address -->
            <TextBlock Grid.Row="3" VerticalAlignment="Top" FontSize="13" Foreground="#333" Margin="0,4,0,0">
                <Run Text="Address"/><Run Text="*" Foreground="Red"/>
            </TextBlock>
            <TextBox x:Name="TxtAddress" Grid.Row="3" Grid.Column="1" FontSize="12" Padding="8,4"
                     Height="70" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,0,0,6"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                <Button x:Name="BtnCancel" Content="Cancel" Click="Cancel_Click" Width="86" Height="32"
                        Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" IsCancel="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#F44336" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnSave" Content="Save" Click="Save_Click" Width="86" Height="32" Margin="8,0,0,0"
                        Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#2E7D32" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
