<Window x:Class="RestaurantPOS.WPF.Views.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Customer"
        Height="540" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#DAEDF4"
        FontFamily="Segoe UI">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4">
            <Run Text="Name:"/><Run Text="*" Foreground="Red"/>
        </TextBlock>
        <TextBox x:Name="TxtName" Grid.Row="1" FontSize="16" Padding="6,6"
                 Height="38" VerticalContentAlignment="Center"
                 BorderBrush="#666" BorderThickness="1" Margin="0,0,0,12"/>

        <!-- Mobile -->
        <TextBlock Grid.Row="2" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4">
            <Run Text="Mobile:"/><Run Text="*" Foreground="Red"/>
        </TextBlock>
        <TextBox x:Name="TxtMobile" Grid.Row="3" FontSize="16" Padding="6,6"
                 Height="38" VerticalContentAlignment="Center"
                 Foreground="Green" FontWeight="SemiBold"
                 BorderBrush="#666" BorderThickness="1" Margin="0,0,0,12"/>

        <!-- Email -->
        <TextBlock Grid.Row="4" Text="Email:" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtEmail" Grid.Row="5" FontSize="16" Padding="6,6"
                 Height="38" VerticalContentAlignment="Center"
                 BorderBrush="#666" BorderThickness="1" Margin="0,0,0,12"/>

        <!-- Address -->
        <TextBlock Grid.Row="6" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4">
            <Run Text="Address:"/><Run Text="*" Foreground="Red"/>
        </TextBlock>
        <TextBox x:Name="TxtAddress" Grid.Row="7" FontSize="14" Padding="6,6"
                 Height="100" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top"
                 BorderBrush="#666" BorderThickness="1" Margin="0,0,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="BtnCancel" Content="Cancel" Click="Cancel_Click"
                    Width="120" Height="42" FontSize="16" FontWeight="Bold"
                    Foreground="White" Cursor="Hand" Margin="0,0,12,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E53935" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="BtnSave" Content="Save" Click="Save_Click"
                    Width="120" Height="42" FontSize="16" FontWeight="Bold"
                    Foreground="White" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#4CAF50" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
