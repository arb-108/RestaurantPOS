<Window x:Class="RestaurantPOS.WPF.Views.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Employee"
        Height="640" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#E9F3F8"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Border Background="White" CornerRadius="8" Padding="18"
                BorderBrush="#DFE9EE" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name -->
                    <TextBlock Grid.Row="0" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">
                        <Run Text="Name:"/><Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox x:Name="TxtName" Grid.Row="0" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"/>

                    <!-- Phone -->
                    <TextBlock Grid.Row="1" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">Phone:</TextBlock>
                    <TextBox x:Name="TxtPhone" Grid.Row="1" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"/>

                    <!-- CNIC -->
                    <TextBlock Grid.Row="2" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">CNIC:</TextBlock>
                    <TextBox x:Name="TxtCNIC" Grid.Row="2" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"/>

                    <!-- Email -->
                    <TextBlock Grid.Row="3" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">Email:</TextBlock>
                    <TextBox x:Name="TxtEmail" Grid.Row="3" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"/>

                    <!-- Category -->
                    <TextBlock Grid.Row="4" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">
                        <Run Text="Category:"/><Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <ComboBox x:Name="CmbCategory" Grid.Row="4" Grid.Column="1" FontSize="14" Height="34"
                              VerticalContentAlignment="Center" BorderBrush="#CCD6DB" Margin="0,4"
                              SelectedIndex="1">
                        <ComboBoxItem Content="Kitchen"/>
                        <ComboBoxItem Content="Service"/>
                        <ComboBoxItem Content="Delivery"/>
                        <ComboBoxItem Content="Management"/>
                        <ComboBoxItem Content="Cleaning"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>

                    <!-- Employment Type -->
                    <TextBlock Grid.Row="5" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">Type:</TextBlock>
                    <ComboBox x:Name="CmbType" Grid.Row="5" Grid.Column="1" FontSize="14" Height="34"
                              VerticalContentAlignment="Center" BorderBrush="#CCD6DB" Margin="0,4"
                              SelectedIndex="0">
                        <ComboBoxItem Content="FullTime"/>
                        <ComboBoxItem Content="PartTime"/>
                        <ComboBoxItem Content="Contract"/>
                        <ComboBoxItem Content="Daily"/>
                    </ComboBox>

                    <!-- Designation -->
                    <TextBlock Grid.Row="6" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">Designation:</TextBlock>
                    <TextBox x:Name="TxtDesignation" Grid.Row="6" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"/>

                    <!-- Joining Date -->
                    <TextBlock Grid.Row="7" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">Joining Date:</TextBlock>
                    <DatePicker x:Name="DpJoining" Grid.Row="7" Grid.Column="1" FontSize="14" Height="34"
                                VerticalContentAlignment="Center" BorderBrush="#CCD6DB" Margin="0,4"/>

                    <!-- Basic Salary -->
                    <TextBlock Grid.Row="8" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">
                        <Run Text="Basic Salary:"/><Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox x:Name="TxtBasicSalary" Grid.Row="8" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"/>

                    <!-- Allowances -->
                    <TextBlock Grid.Row="9" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">Allowances:</TextBlock>
                    <TextBox x:Name="TxtAllowances" Grid.Row="9" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"
                             Text="0"/>

                    <!-- Deductions -->
                    <TextBlock Grid.Row="10" VerticalAlignment="Center" FontSize="13" Foreground="#333" Margin="0,6">Deductions:</TextBlock>
                    <TextBox x:Name="TxtDeductions" Grid.Row="10" Grid.Column="1" FontSize="14" Height="34" Padding="8,4"
                             VerticalContentAlignment="Center" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"
                             Text="0"/>

                    <!-- Address + Emergency -->
                    <TextBlock Grid.Row="11" VerticalAlignment="Top" FontSize="13" Foreground="#333" Margin="0,6">Address:</TextBlock>
                    <TextBox x:Name="TxtAddress" Grid.Row="11" Grid.Column="1" FontSize="13" Padding="8,4"
                             Height="50" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" BorderBrush="#CCD6DB" BorderThickness="1" Margin="0,4"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button x:Name="BtnCancel" Content="Cancel" Click="Cancel_Click"
                                Width="100" Height="36" Margin="0,0,10,0"
                                Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" IsCancel="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#F44336" CornerRadius="6" Padding="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnSave" Content="Save" Click="Save_Click"
                                Width="100" Height="36"
                                Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" IsDefault="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#2E7D32" CornerRadius="6" Padding="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
