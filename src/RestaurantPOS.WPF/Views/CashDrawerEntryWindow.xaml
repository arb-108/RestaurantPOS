<Window x:Class="RestaurantPOS.WPF.Views.CashDrawerEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Drawer Entry" Width="440" Height="370"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,16">
                <!-- Header -->
                <TextBlock x:Name="TxtTitle" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,4"/>
                <TextBlock Text="Enter amount and description for this transaction"
                           FontSize="12" Foreground="#6B7280" Margin="0,0,0,22"/>

                <!-- Amount -->
                <TextBlock Text="AMOUNT (RS)" FontSize="10" Foreground="#6B7280"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtAmount" FontSize="20" FontWeight="Bold"
                         Padding="14,10" Background="White" BorderBrush="#D97706"
                         BorderThickness="2" Text="0" TextAlignment="Right">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Description -->
                <TextBlock Text="DESCRIPTION" FontSize="10" Foreground="#6B7280"
                           FontWeight="SemiBold" Margin="0,18,0,6"/>
                <TextBox x:Name="TxtDesc" FontSize="13" Padding="10,8" Background="White"
                         BorderBrush="#D1D5DB" BorderThickness="1" Height="70"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Fixed Buttons at Bottom -->
        <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Background="#F9FAFB" Padding="32,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Height="38" FontSize="13" FontWeight="SemiBold"
                        Background="Transparent" BorderBrush="#D1D5DB" BorderThickness="1"
                        Foreground="#4B5563" Cursor="Hand" Click="CancelClick" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12,6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Save" Width="110" Height="38" FontSize="13" FontWeight="Bold"
                        Background="#D97706" Foreground="White" BorderThickness="0" Cursor="Hand" Click="SaveClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="12,6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#B45309"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
