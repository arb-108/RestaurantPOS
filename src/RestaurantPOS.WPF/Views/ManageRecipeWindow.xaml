<Window x:Class="RestaurantPOS.WPF.Views.ManageRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Recipe" Height="560" Width="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F7FA" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#37474F"/><Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/><Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/><Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Product info banner -->
        <Border Grid.Row="0" Background="#E3F2FD" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="TxtProductName" FontSize="15" FontWeight="Bold" Foreground="#1565C0"/>
                <TextBlock x:Name="TxtProductInfo" FontSize="11" Foreground="#546E7A" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Ingredient picker row -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="10,8" Margin="0,0,0,8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="CmbIngredient" FontSize="12" Height="30" Padding="6,4"
                              DisplayMemberPath="Name" VerticalContentAlignment="Center"
                              SelectionChanged="CmbIngredient_SelectionChanged"/>
                    <TextBox x:Name="TxtQty" Grid.Column="1" FontSize="12" Height="30" Padding="6,4" Text="1"
                             Margin="8,0,0,0" BorderBrush="#CBD5E1" BorderThickness="1" VerticalContentAlignment="Center"/>
                    <TextBlock x:Name="TxtUnit" Grid.Column="2" FontSize="11" Foreground="#78909C"
                               VerticalAlignment="Center" Margin="6,0,6,0"/>
                    <Button Grid.Column="3" Content="+ Add" Click="AddIngredient_Click" FontSize="12" FontWeight="SemiBold"
                            Background="#1565C0" Foreground="White" Padding="14,4" Height="30" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <TextBlock Grid.Row="1" Text="Only stock items can be used. Add new ingredients in Stock Management first."
                           FontSize="10" Foreground="#90A4AE" Margin="0,5,0,0" FontStyle="Italic"/>
            </Grid>
        </Border>

        <!-- Ingredients list -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#F9FAFB" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ingredient" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Qty" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Unit" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Cost/Unit" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="Line Cost" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <ListView x:Name="LstRecipeItems" Grid.Row="1" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding QuantityText}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Unit}" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding CostText}" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#546E7A"/>
                                <TextBlock Grid.Column="4" Text="{Binding LineCostText}" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#15803D"/>
                                <Button Grid.Column="5" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        Foreground="#DC2626" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="RemoveIngredient_Click" Tag="{Binding}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Totals -->
                <Border Grid.Row="2" Background="#F8FAFC" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock FontSize="12" Foreground="#475569">
                            <Run Text="Ingredients: "/><Run x:Name="RunCount" Text="0" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="Bold" Foreground="#1565C0">
                            <Run Text="Total Cost: Rs "/><Run x:Name="RunTotalCost" Text="0"/>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="Cancel_Click" FontSize="13" FontWeight="SemiBold"
                    Background="#E53935" Foreground="White" Padding="20,6" Height="36" Cursor="Hand" BorderThickness="0" Margin="0,0,8,0">
                <Button.Template><ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate></Button.Template>
            </Button>
            <Button Content="Save Recipe" Click="Save_Click" FontSize="13" FontWeight="SemiBold"
                    Background="#1565C0" Foreground="White" Padding="20,6" Height="36" Cursor="Hand" BorderThickness="0">
                <Button.Template><ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate></Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
