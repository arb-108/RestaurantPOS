<Window x:Class="RestaurantPOS.WPF.Views.GeneratePayrollWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate Monthly Payroll"
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#E9F3F8"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Month/Year selection -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Month:" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="CmbMonth" Width="120" Height="32" FontSize="13" VerticalContentAlignment="Center">
                <ComboBoxItem Content="January"/>
                <ComboBoxItem Content="February"/>
                <ComboBoxItem Content="March"/>
                <ComboBoxItem Content="April"/>
                <ComboBoxItem Content="May"/>
                <ComboBoxItem Content="June"/>
                <ComboBoxItem Content="July"/>
                <ComboBoxItem Content="August"/>
                <ComboBoxItem Content="September"/>
                <ComboBoxItem Content="October"/>
                <ComboBoxItem Content="November"/>
                <ComboBoxItem Content="December"/>
            </ComboBox>
            <TextBlock Text="Year:" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <TextBox x:Name="TxtYear" Width="80" Height="32" FontSize="14" Padding="6,4"
                     VerticalContentAlignment="Center" BorderBrush="#CCD6DB"/>
        </StackPanel>

        <!-- Employee payroll grid -->
        <DataGrid Grid.Row="1" x:Name="PayrollGrid" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="False"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEE"
                  BorderThickness="1" BorderBrush="#E0E0E0" Background="White"
                  FontSize="12" RowHeight="32" ColumnHeaderHeight="30">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="30"/>
                <DataGridTextColumn Header="Employee" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" IsReadOnly="True" Width="80"/>
                <DataGridTextColumn Header="Basic" Binding="{Binding BasicDisplay}" IsReadOnly="True" Width="80"/>
                <DataGridTextColumn Header="Allow." Binding="{Binding AllowDisplay}" IsReadOnly="True" Width="70"/>
                <DataGridTextColumn Header="Deduct." Binding="{Binding DeductDisplay}" IsReadOnly="True" Width="70"/>
                <DataGridTextColumn Header="Bonus" Binding="{Binding BonusInput, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Advance" Binding="{Binding AdvanceInput, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Net" Binding="{Binding NetDisplay}" IsReadOnly="True" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Width="100" Height="36" Margin="0,0,10,0"
                    Foreground="White" FontWeight="SemiBold" Cursor="Hand" IsCancel="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#F44336" CornerRadius="6" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Generate" Click="Generate_Click" Width="120" Height="36"
                    Foreground="White" FontWeight="SemiBold" Cursor="Hand" IsDefault="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#2E7D32" CornerRadius="6" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
