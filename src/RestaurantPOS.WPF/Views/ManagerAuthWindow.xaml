<Window x:Class="RestaurantPOS.WPF.Views.ManagerAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authorization Required"
        Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#DAEDF4"
        FontFamily="Segoe UI">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Shield icon + message -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                       FontSize="28" Foreground="#1565C0"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Text="Admin or Manager authorization required&#x0a;to proceed with this action."
                       FontSize="14" Foreground="#333"
                       TextWrapping="Wrap" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Username -->
        <TextBlock Grid.Row="1" Text="Username" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtUsername" Grid.Row="2" FontSize="14" Padding="8,6"
                 BorderBrush="#666" BorderThickness="1" Margin="0,0,0,10"/>

        <!-- Password -->
        <TextBlock Grid.Row="3" Text="Password" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <PasswordBox x:Name="TxtPassword" Grid.Row="4" FontSize="14" Padding="8,6"
                     BorderBrush="#666" BorderThickness="1" Margin="0,0,0,10"/>

        <!-- Error message -->
        <TextBlock x:Name="TxtError" Grid.Row="5" Foreground="#D32F2F" FontSize="12"
                   TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,0,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click"
                    Width="110" Height="40" FontSize="15" FontWeight="Bold"
                    Foreground="White" Cursor="Hand" Margin="0,0,12,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#9E9E9E" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Authorize" Click="Authorize_Click"
                    Width="110" Height="40" FontSize="15" FontWeight="Bold"
                    Foreground="White" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1565C0" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
