<Window x:Class="RestaurantPOS.WPF.Views.DatabaseSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Settings"
        Width="560" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="White" BorderBrush="#9CA3AF" BorderThickness="1" CornerRadius="4" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D6F9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Field" TargetType="Control">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="32"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#4682B4" BorderThickness="2" Background="White" CornerRadius="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#4682B4" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Database Settings" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Style="{StaticResource TitleBtn}" Content="&#xE8BB;" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Banner -->
            <Border Grid.Row="1" Background="#EFF6FF" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="SQL Server Configuration" FontSize="15" FontWeight="Bold" Foreground="#1E40AF"/>
                    <TextBlock Text="Configure the connection to your SQL Server instance. Click Test Connection before saving."
                               FontSize="11" Foreground="#1E3A8A" TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Form -->
            <Grid Grid.Row="2" Margin="20,16,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Server -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="SQL Server Name:" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtServer" Style="{StaticResource Field}"
                         VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <!-- Database -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Database Name:" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtDatabase" Style="{StaticResource Field}"
                         VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <!-- Authentication -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Authentication:" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CmbAuth" Style="{StaticResource Field}"
                          VerticalContentAlignment="Center" Margin="0,0,0,10"
                          SelectionChanged="CmbAuth_SelectionChanged">
                    <ComboBoxItem Content="Windows Authentication" Tag="windows"/>
                    <ComboBoxItem Content="SQL Server Authentication" Tag="sql"/>
                </ComboBox>

                <!-- Username -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="SQL User Name:" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtUsername" Style="{StaticResource Field}"
                         VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <!-- Password -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="SQL Password:" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="TxtPassword" Style="{StaticResource Field}"
                             VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <!-- Test result -->
                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                        x:Name="StatusPanel"
                        Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="4" Padding="12" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtStatusTitle" Text="Ready" FontSize="12" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="TxtStatusMessage"
                                   Text="Enter your SQL Server details and click Test Connection to verify."
                                   FontSize="11" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100"
                                     Margin="0,6,0,0" IsIndeterminate="False" Visibility="Collapsed"
                                     Background="#E5E7EB" Foreground="#4682B4" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="16,10" Margin="0,12,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnTest" Style="{StaticResource ActionBtn}" Background="#2563EB"
                                Width="170" Height="34" Click="Test_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Test Connection" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryBtn}" Content="Cancel" Width="90" Height="32" Margin="0,0,8,0" Click="Close_Click"/>
                        <Button x:Name="BtnSave" Style="{StaticResource ActionBtn}" Background="#059669"
                                Content="Save &amp; Close" Width="140" Height="32" Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
