<Window x:Class="RestaurantPOS.WPF.Views.AddDealWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Deal" Height="620" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F7FA" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#37474F"/><Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/><Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/><Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Deal info -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Style="{StaticResource Lbl}" Text="Deal Name *"/>
                <TextBox x:Name="txtName" Style="{StaticResource Inp}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                <TextBlock Style="{StaticResource Lbl}" Text="Category"/>
                <ComboBox x:Name="cmbCategory" FontSize="13" Height="32" Padding="6,4"
                          DisplayMemberPath="Name" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Style="{StaticResource Lbl}" Text="Deal Price (Rs) *"/>
                <TextBox x:Name="txtDealPrice" Style="{StaticResource Inp}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                <TextBlock Style="{StaticResource Lbl}" Text="Display Order"/>
                <TextBox x:Name="txtOrder" Style="{StaticResource Inp}" Text="0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,4">
                <TextBlock Style="{StaticResource Lbl}" Text="Description"/>
                <TextBox x:Name="txtDescription" Style="{StaticResource Inp}" Height="Auto" MinHeight="32" TextWrapping="Wrap" AcceptsReturn="False"/>
            </StackPanel>
        </Grid>

        <!-- Middle: Item selection -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Add item row -->
            <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10,8" Margin="0,0,0,8" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="cmbMenuItem" FontSize="12" Height="30" Padding="6,4"
                              DisplayMemberPath="Name" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtQty" Grid.Column="1" FontSize="12" Height="30" Padding="6,4" Text="1"
                             Margin="8,0,8,0" BorderBrush="#CBD5E1" BorderThickness="1" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="+ Add Item" Click="AddItem_Click" FontSize="12" FontWeight="SemiBold"
                            Background="#1565C0" Foreground="White" Padding="12,4" Height="30" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Items list -->
            <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#1E3A5F" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="80"/><ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Qty" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Price" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ListView x:Name="lstItems" Grid.Row="1" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="80"/><ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ItemName}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding PriceText}" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#15803D"/>
                                    <Button Grid.Column="3" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                            Foreground="#DC2626" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Click="RemoveItem_Click" Tag="{Binding}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Totals -->
                    <Border Grid.Row="2" Background="#F8FAFC" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock FontSize="12" FontWeight="Bold" Foreground="#475569">
                                <Run Text="Original Total: Rs. "/><Run x:Name="runOriginal" Text="0"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="Bold" Foreground="#C62828">
                                <Run Text="You Save: Rs. "/><Run x:Name="runSaving" Text="0"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="Cancel_Click" FontSize="13" FontWeight="SemiBold"
                    Background="#E53935" Foreground="White" Padding="20,6" Height="36" Cursor="Hand" BorderThickness="0" Margin="0,0,8,0">
                <Button.Template><ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate></Button.Template>
            </Button>
            <Button Content="Save Deal" Click="Save_Click" FontSize="13" FontWeight="SemiBold"
                    Background="#1565C0" Foreground="White" Padding="20,6" Height="36" Cursor="Hand" BorderThickness="0">
                <Button.Template><ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate></Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
