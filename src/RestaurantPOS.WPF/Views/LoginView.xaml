<UserControl x:Class="RestaurantPOS.WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:RestaurantPOS.WPF.Converters"
             mc:Ignorable="d"
             Background="{StaticResource PrimaryBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Background="White" CornerRadius="12" Padding="40,30"
                MinWidth="400" MinHeight="500">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>

            <StackPanel HorizontalAlignment="Center">
                <!-- Logo / Title -->
                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                           FontSize="48" HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <TextBlock Text="KFC Restaurant" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Point of Sale System" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- PIN Display -->
                <Border Background="{StaticResource PrimaryBgBrush}" CornerRadius="6"
                        Padding="16,12" Margin="0,0,0,16"
                        Visibility="{Binding ShowPinPad, Converter={StaticResource BoolToVis}}"
                        x:Name="PinSection">
                    <TextBlock Text="{Binding PinEntry, FallbackValue='****'}"
                               FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               MinWidth="200" TextAlignment="Center"/>
                </Border>

                <!-- PIN Pad -->
                <Grid Visibility="{Binding ShowPinPad, Converter={StaticResource BoolToVis}}"
                      HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="1"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="2"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="3"/>
                    <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="4"/>
                    <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="5"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="6"/>
                    <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="7"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="8"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="9"/>
                    <Button Grid.Row="3" Grid.Column="0" Content="C" Style="{StaticResource PinButton}"
                            Command="{Binding ClearPinCommand}" Foreground="{StaticResource DangerBrush}"/>
                    <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource PinButton}" Command="{Binding AppendPinCommand}" CommandParameter="0"/>
                    <Button Grid.Row="3" Grid.Column="2" Content="&#x232B;" Style="{StaticResource PinButton}"
                            Command="{Binding BackspacePinCommand}" FontSize="22"/>
                </Grid>

                <!-- Login Button (PIN) -->
                <Button Content="LOGIN WITH PIN" Style="{StaticResource CheckoutButton}"
                        Command="{Binding LoginWithPinCommand}"
                        Visibility="{Binding ShowPinPad, Converter={StaticResource BoolToVis}}"
                        Width="280" Margin="0,8,0,0"/>

                <!-- Password Login Section -->
                <StackPanel Visibility="{Binding ShowPasswordLogin, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,8">
                    <TextBlock Text="Username" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="8" Margin="0,0,0,12"/>
                    <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox" FontSize="14" Padding="8" Margin="0,0,0,12"/>
                    <Button Content="LOGIN" Style="{StaticResource CheckoutButton}"
                            Command="{Binding LoginWithPasswordCommand}"
                            Width="280"/>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                           FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"
                           TextWrapping="Wrap"/>

                <!-- Toggle Login Mode -->
                <Button HorizontalAlignment="Center" Margin="0,16,0,0"
                        Command="{Binding ToggleLoginModeCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="Switch Login Mode" TextDecorations="Underline"
                                       Foreground="{StaticResource AccentBrush}" FontSize="12" Cursor="Hand"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
