<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ COLOR PALETTE (matching reference UI) ═══ -->
    <Color x:Key="PrimaryBgColor">#E8F0FE</Color>
    <Color x:Key="SecondaryBgColor">#D0E4F5</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="TitleBarColor">#0D47A1</Color>
    <Color x:Key="ToolbarBgColor">#F5F5F5</Color>
    <Color x:Key="AccentColor">#2196F3</Color>
    <Color x:Key="HoldColor">#B3B8B9</Color>
    <Color x:Key="AccentDarkColor">#1565C0</Color>
    <Color x:Key="SuccessColor">#00C853</Color>
    <Color x:Key="SuccessDarkColor">#00897B</Color>
    <Color x:Key="DangerColor">#E53935</Color>
    <Color x:Key="WarningColor">#FF8F00</Color>
    <Color x:Key="CategoryColor">#1565C0</Color>
    <Color x:Key="CategoryActiveColor">#0D47A1</Color>
    <Color x:Key="TableAvailableColor">#F9A825</Color>
    <Color x:Key="TableOccupiedColor">#4CAF50</Color>
    <Color x:Key="MenuCardColor">#F5C518</Color>
    <Color x:Key="MenuCardBorderColor">#D4A017</Color>
    <Color x:Key="DeliveryRedColor">#F44336</Color>
    <Color x:Key="TakeawayBlueColor">#2962FF</Color>
    <Color x:Key="TextPrimaryColor">#212121</Color>
    <Color x:Key="TextSecondaryColor">#607D8B</Color>
    <Color x:Key="TextDarkBlue">#1A237E</Color>
    <Color x:Key="NetTotalRedColor">#D32F2F</Color>
    <Color x:Key="KBillDarkColor">#1A237E</Color>
    <Color x:Key="BillPrintTealColor">#4DB6AC</Color>
    <Color x:Key="UpdateBillBlueColor">#42A5F5</Color>
    <Color x:Key="UnPaidBillDarkColor">#37474F</Color>
    <Color x:Key="GridHeaderColor">#E3F2FD</Color>
    <Color x:Key="GridHeaderBorderColor">#90CAF9</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBgBrush" Color="{StaticResource PrimaryBgColor}"/>
    <SolidColorBrush x:Key="SecondaryBgBrush" Color="{StaticResource SecondaryBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="TitleBarBrush" Color="{StaticResource TitleBarColor}"/>
    <SolidColorBrush x:Key="ToolbarBgBrush" Color="{StaticResource ToolbarBgColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="HoldBrush" Color="{StaticResource HoldColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessDarkBrush" Color="{StaticResource SuccessDarkColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="CategoryBrush" Color="{StaticResource CategoryColor}"/>
    <SolidColorBrush x:Key="CategoryActiveBrush" Color="{StaticResource CategoryActiveColor}"/>
    <SolidColorBrush x:Key="TableAvailableBrush" Color="{StaticResource TableAvailableColor}"/>
    <SolidColorBrush x:Key="TableOccupiedBrush" Color="{StaticResource TableOccupiedColor}"/>
    <SolidColorBrush x:Key="MenuCardBrush" Color="{StaticResource MenuCardColor}"/>
    <SolidColorBrush x:Key="MenuCardBorderBrush" Color="{StaticResource MenuCardBorderColor}"/>
    <SolidColorBrush x:Key="DeliveryRedBrush" Color="{StaticResource DeliveryRedColor}"/>
    <SolidColorBrush x:Key="TakeawayBlueBrush" Color="{StaticResource TakeawayBlueColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDarkBlueBrush" Color="{StaticResource TextDarkBlue}"/>
    <SolidColorBrush x:Key="NetTotalRedBrush" Color="{StaticResource NetTotalRedColor}"/>
    <SolidColorBrush x:Key="KBillDarkBrush" Color="{StaticResource KBillDarkColor}"/>
    <SolidColorBrush x:Key="BillPrintTealBrush" Color="{StaticResource BillPrintTealColor}"/>
    <SolidColorBrush x:Key="UpdateBillBlueBrush" Color="{StaticResource UpdateBillBlueColor}"/>
    <SolidColorBrush x:Key="UnPaidBillDarkBrush" Color="{StaticResource UnPaidBillDarkColor}"/>
    <SolidColorBrush x:Key="GridHeaderBrush" Color="{StaticResource GridHeaderColor}"/>
    <SolidColorBrush x:Key="GridHeaderBorderBrush" Color="{StaticResource GridHeaderBorderColor}"/>
    <SolidColorBrush x:Key="TableGreenBrush" Color="#4CAF50"/>

    <!-- ═══ GLOBAL FONT ═══ -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>

    <!-- ═══ TOOLBAR BUTTON (Icon + Label, rectangular) ═══ -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="MinWidth" Value="70"/>
        <Setter Property="Height" Value="62"/>
        <Setter Property="Margin" Value="1,0"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderThickness="0" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#BBDEFB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ CATEGORY BUTTON (Blue, full-width) ═══ -->
    <Style x:Key="CategoryButton" TargetType="Button">
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource CategoryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Padding="4,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CategoryActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0A3D91"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ MENU ITEM CARD (Golden/Yellow with cart icon) ═══ -->
    <Style x:Key="MenuItemCard" TargetType="Button">
        <Setter Property="Width" Value="145"/>
        <Setter Property="Height" Value="70"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            CornerRadius="4"
                            Padding="8,6"
                            BorderThickness="1"
                            BorderBrush="{StaticResource MenuCardBorderBrush}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFD54F" Offset="0"/>
                                <GradientStop Color="#F9A825" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#E65100"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ TABLE BUTTON (Yellow/Gold with icon and floor info) ═══ -->
    <Style x:Key="TableButton" TargetType="Button">
        <Setter Property="Height" Value="55"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Background" Value="{StaticResource TableAvailableBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="6,4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ DELIVERY BUTTON (Red) ═══ -->
    <Style x:Key="DeliveryButton" TargetType="Button">
        <Setter Property="Height" Value="50"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource DeliveryRedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="12,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ TAKEAWAY BUTTON (Blue) ═══ -->
    <Style x:Key="TakeawayButton" TargetType="Button" BasedOn="{StaticResource DeliveryButton}">
        <Setter Property="Background" Value="{StaticResource TakeawayBlueBrush}"/>
    </Style>

    <!-- ═══ ACTION BUTTONS ═══ -->
    <Style x:Key="CheckoutButton" TargetType="Button">
        <Setter Property="Height" Value="42"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="20,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="Black"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="34"/>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="34"/>
    </Style>
    <Style x:Key="HoldButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource HoldBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="34"/>
    </Style>

    <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="34"/>
    </Style>

    <Style x:Key="KBillButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource KBillDarkBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="38"/>
    </Style>

    <Style x:Key="BillPrintButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource BillPrintTealBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="38"/>
    </Style>

    <Style x:Key="UpdateBillButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource UpdateBillBlueBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Height" Value="34"/>
    </Style>

    <Style x:Key="UnPaidBillButton" TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
        <Setter Property="Background" Value="{StaticResource UnPaidBillDarkBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Height" Value="34"/>
    </Style>

    <!-- ═══ ORDER TYPE TOGGLE BUTTON ═══ -->
    <Style x:Key="OrderTypeButton" TargetType="ToggleButton">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="12,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ TAB HEADER STYLE ═══ -->
    <Style x:Key="TabHeaderText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,0,20,0"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- ═══ PIN PAD BUTTON ═══ -->
    <Style x:Key="PinButton" TargetType="Button">
        <Setter Property="Width" Value="80"/>
        <Setter Property="Height" Value="80"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryBgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ QUANTITY +/- BUTTONS ═══ -->
    <Style x:Key="QtyPlusButton" TargetType="Button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#4CAF50"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="QtyMinusButton" TargetType="Button" BasedOn="{StaticResource QtyPlusButton}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    </Style>

    <!-- ═══ ADD TABLE (+) BUTTON ═══ -->
    <Style x:Key="AddTableButton" TargetType="Button">
        <Setter Property="Height" Value="55"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Background" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#BDBDBD"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ ORDER HEADER INFO BOX ═══ -->
    <Style x:Key="OrderHeaderBox" TargetType="Border">
        <Setter Property="BorderBrush" Value="#90CAF9"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2,0"/>
    </Style>

</ResourceDictionary>
